<div class="password-field">
    @if (visible)
    {
        <RadzenTextBox Value="@Value"
                       ValueChanged="@OnValueChanged"
                       Name="@Name"
                       Placeholder="@Placeholder"
                       Style="width:100%;"
                       Disabled="@Disabled" />
    }
    else
    {
        <RadzenPassword Value="@Value"
                        ValueChanged="@OnValueChanged"
                        Name="@Name"
                        Placeholder="@Placeholder"
                        Style="width:100%;"
                        Disabled="@Disabled" />
    }
    <button type="button"
            class="password-toggle-btn"
            aria-label="@(visible ? "Şifreyi gizle" : "Şifreyi göster")"
            aria-pressed="@(visible ? "true" : "false")"
            disabled="@Disabled"
            @onclick="ToggleVisible">
        <i class="fa-solid @(visible ? "fa-eye-slash" : "fa-eye")" aria-hidden="true"></i>
    </button>
</div>

@code {
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter, EditorRequired] public string Name { get; set; } = string.Empty;
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private bool visible;

    private async Task OnValueChanged(string value) => await ValueChanged.InvokeAsync(value);

    private void ToggleVisible() => visible = !visible;
}
