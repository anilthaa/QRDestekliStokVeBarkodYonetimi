@inject DataService DataSvc
@inject AuthStateService AuthState
@inject DialogService DialogSvc
@inject NotificationService NotificationSvc

<RadzenTemplateForm TItem="ItemKullanicilar" Data="@model" Submit="@OnSubmitAsync">

    <div class="rz-p-4" style="min-width:480px; display:flex; flex-direction:column; gap:1rem;">

        <div style="display:flex; gap:1rem;">
            <div style="flex:1;">
                <RadzenLabel Text="Ad *" Component="Ad" />
                <RadzenTextBox @bind-Value="model.Ad" Name="Ad" Placeholder="Ad giriniz"
                               Style="width:100%" Disabled="@isBusy" />
                <RadzenRequiredValidator Component="Ad" Text="Ad zorunludur." Style="display:block" />
            </div>
            <div style="flex:1;">
                <RadzenLabel Text="Soyad *" Component="Soyad" />
                <RadzenTextBox @bind-Value="model.Soyad" Name="Soyad" Placeholder="Soyad giriniz"
                               Style="width:100%" Disabled="@isBusy" />
                <RadzenRequiredValidator Component="Soyad" Text="Soyad zorunludur." Style="display:block" />
            </div>
        </div>

        <div>
            <RadzenLabel Text="E-posta *" Component="Eposta" />
            <RadzenTextBox @bind-Value="model.Eposta" Name="Eposta" Placeholder="eposta@ornek.com"
                           Style="width:100%" Disabled="@isBusy" InputType="email" />
            <RadzenRequiredValidator Component="Eposta" Text="E-posta zorunludur." Style="display:block" />
        </div>

        <div>
            <RadzenLabel Text="@(model.ID == 0 ? "Şifre *" : "Şifre (değiştirmek için doldurun)")" Component="Sifre" />
            <RadzenPassword @bind-Value="model.Sifre" Name="Sifre"
                            Placeholder="@(model.ID == 0 ? "En az 6 karakter" : "Boş bırakılırsa değişmez")"
                            Style="width:100%" Disabled="@isBusy" />
            @if (model.ID == 0)
            {
                <RadzenRequiredValidator Component="Sifre" Text="Şifre zorunludur." Style="display:block" />
            }
        </div>

        <div>
            <RadzenLabel Text="Kullanıcı Tipi *" Component="KullaniciTip_ID" />
            <RadzenDropDown @bind-Value="model.KullaniciTip_ID" Name="KullaniciTip_ID"
                            Data="@kullaniciTipler" TextProperty="Ad" ValueProperty="ID"
                            Placeholder="Kullanıcı tipi seçiniz" Style="width:100%"
                            Disabled="@isBusy" AllowClear="true" />
            <RadzenRequiredValidator Component="KullaniciTip_ID" Text="Kullanıcı tipi zorunludur." Style="display:block" />
        </div>

        <div style="display:flex; align-items:center; gap:0.5rem;">
            <RadzenCheckBox @bind-Value="model.Aktif" Name="Aktif" Disabled="@isBusy" />
            <RadzenLabel Text="Aktif" Component="Aktif" />
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat"
                         AllowClose="false">@errorMessage</RadzenAlert>
        }

        <div style="display:flex; justify-content:flex-end; gap:0.5rem; margin-top:0.5rem;">
            <RadzenButton ButtonStyle="ButtonStyle.Light" Text="İptal" Icon="cancel"
                          Click="@OnCancel" Disabled="@isBusy" />
            <RadzenButton ButtonType="ButtonType.Submit" Text="Kaydet" Icon="save"
                          IsBusy="@isBusy" BusyText="Kaydediliyor..." />
        </div>

    </div>

</RadzenTemplateForm>

@code {
    [Parameter] public ItemKullanicilar? Item { get; set; }

    private ItemKullanicilar model = new() { Aktif = true };
    private bool isBusy;
    private string? errorMessage;

    private ItemKullaniciTip[] kullaniciTipler = [];

    protected override async Task OnInitializedAsync()
    {
        kullaniciTipler = await DataSvc.GetKullaniciTip();
    }

    protected override void OnParametersSet()
    {
        if (Item is not null)
        {
            model = new ItemKullanicilar
            {
                ID              = Item.ID,
                KullaniciTip_ID = Item.KullaniciTip_ID,
                Ad              = Item.Ad,
                Soyad           = Item.Soyad,
                Eposta          = Item.Eposta,
                Sifre           = string.Empty,   // güvenlik: şifreyi forma taşımıyoruz
                Aktif           = Item.Aktif,
                CreUser         = Item.CreUser,
                CreDate         = Item.CreDate,
                UpdUser         = Item.UpdUser,
                UpdDate         = Item.UpdDate,
                DelUser         = Item.DelUser,
                DelDate         = Item.DelDate
            };
        }
    }

    private async Task OnSubmitAsync()
    {
        errorMessage = null;
        isBusy = true;
        try
        {
            int userId = AuthState.CurrentUser?.ID ?? 0;

            if (model.ID == 0)
                model.CreUser = userId;
            else
                model.UpdUser = userId;

            model.DelUser = 0;

            var result = await DataSvc.SetKullanici(model);

            if (result.SonucKodu < 0)
            {
                errorMessage = result.SonucAciklama ?? "Bir hata oluştu.";
                return;
            }

            NotificationSvc.Notify(NotificationSeverity.Success, "Başarılı",
                model.ID == 0 ? "Kullanıcı eklendi." : "Kullanıcı güncellendi.", 3000);

            DialogSvc.Close(true);
        }
        catch (Exception ex)
        {
            errorMessage = $"Beklenmeyen hata: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private void OnCancel() => DialogSvc.Close(false);
}