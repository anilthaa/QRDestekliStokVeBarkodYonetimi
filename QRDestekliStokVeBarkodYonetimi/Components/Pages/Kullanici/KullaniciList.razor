@page "/kullanicilar"
@layout QRDestekliStokVeBarkodYonetimi.Components.Layout.MainLayout
@rendermode InteractiveServer

@inject NavigationManager Nav
@inject YetkiService YetkiSvc

@implements IDisposable

<PageTitle>Kullanıcılar</PageTitle>

<div class="page-header">
    <h3 class="page-header-title">Kullanıcı Listesi</h3>
    <div class="page-header-actions">
        <ExportButton TItem="ItemKullanicilar"
                      Items="@kullanicilar"
                      Title="Kullanıcı Listesi"
                      FileName="kullanici-listesi"
                      Columns="@CiktiKolonlari()" />
        <RadzenButton Text="Yeni Kullanıcı" Icon="person_add" ButtonStyle="ButtonStyle.Primary"
                      Click="@OnYeniClick"
                      Disabled="@sadecOkuma"
                      Style="@(sadecOkuma ? "opacity:0.35;pointer-events:none;" : "")" />
    </div>
</div>

@if (isLoading)
{
    <div style="display:flex; justify-content:center; padding:2rem;">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                   Size="ProgressBarCircularSize.Large" />
    </div>
}
else
{
    <RadzenDataGrid @ref="gridRef" Data="@filtreliKullanicilar" TItem="ItemKullanicilar" AllowSorting="true"
                    AllowFiltering="true" FilterMode="FilterMode.Simple"
                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                    AllowPaging="false" AllowVirtualization="true" PageSize="25"
                    VirtualizationOverscanCount="3"
                    EmptyText="Kayıt bulunamadı."
                    ColumnWidth="200px"
                    class="liste-grid-virtual">
        <Columns>
            <RadzenDataGridColumn TItem="ItemKullanicilar" Property="ID" Title="Sıra" Width="@GridSiraYardimci.KolonGenisligi" MinWidth="@GridSiraYardimci.KolonGenisligi"
                                  Frozen="true" Filterable="false"
                                  SortComparer="@GridSiraYardimci.SiralamaIndeksiComparer(filtreliKullanicilar)"
                                  TextAlign="TextAlign.Center" CssClass="grid-sira-kolon">
                <Template Context="row">
                    @GridSiraYardimci.ListeSirasi(filtreliKullanicilar, row)
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ItemKullanicilar" Title="" Width="64px" Frozen="true"
                                  Sortable="false" Filterable="false" TextAlign="TextAlign.Center">
                <Template Context="row">
                    <div class="kullanici-liste-avatar" title="Profil">
                        @if (!string.IsNullOrWhiteSpace(row.ProfilResmi))
                        {
                            <img src="@($"{row.ProfilResmi}?v={row.UpdDate?.Ticks ?? row.ID}")" alt="" />
                        }
                        else
                        {
                            @Initials(row)
                        }
                    </div>
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ItemKullanicilar" Property="Ad" Title="Ad" MinWidth="130px" />
            <RadzenDataGridColumn TItem="ItemKullanicilar" Property="Soyad" Title="Soyad" MinWidth="130px" />
            <RadzenDataGridColumn TItem="ItemKullanicilar" Property="Eposta" Title="E-posta" MinWidth="200px" />
            <RadzenDataGridColumn TItem="ItemKullanicilar" Property="KullaniciTip_ID" Title="Kullanıcı Tipi" MinWidth="150px">
                <Template Context="row">
                    @(kullaniciTipler.FirstOrDefault(k => k.ID == row.KullaniciTip_ID)?.Ad ?? "-")
                </Template>
                <FilterTemplate>
                    <GridLookupFilter @bind-Value="@kullaniciTipFiltreId" Data="@kullaniciTipler" />
                </FilterTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ItemKullanicilar" Property="Aktif" Title="Aktif" Width="90px" TextAlign="TextAlign.Center">
                <Template Context="row">
                    <RadzenIcon Icon="@(row.Aktif == true ? "check_circle" : "cancel")"
                                Style="@(row.Aktif == true ? "color:#2e7d32" : "color:#c62828")" />
                </Template>
                <FilterTemplate>
                    <GridBoolFilter @bind-Value="@aktifFiltre" />
                </FilterTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ItemKullanicilar" Title="" Width="48px" TextAlign="TextAlign.Center"
                                  Sortable="false" Filterable="false">
                <Template Context="row">
                    <GridIslemMenuButonu Click="@(e => IslemlerMenuAc(e, row))" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@code {
    private RadzenDataGrid<ItemKullanicilar>? gridRef;
    private ItemKullanicilar[] kullanicilar = [];
    private ItemKullaniciTip[] kullaniciTipler = [];
    private bool isLoading = true;
    private bool sadecOkuma = false;
    private bool yetkiSayfasiErisim = false;
    private int? onayMailiGonderiliyorId;
    private string siteBaseUri = string.Empty;
    private int? kullaniciTipFiltreId;
    private bool? aktifFiltre;
    private ItemKullanicilar? menuSatir;

    private ItemKullanicilar[] filtreliKullanicilar => kullanicilar.Where(k =>
        GridFilterHelper.IdEslesir(k.KullaniciTip_ID, kullaniciTipFiltreId) &&
        GridFilterHelper.BoolEslesir(k.Aktif, aktifFiltre)).ToArray();

    private IList<ExportColumn<ItemKullanicilar>> CiktiKolonlari()
    {
        var liste = kullanicilar.ToList();
        return new List<ExportColumn<ItemKullanicilar>>
    {
        new() { Header = "Sıra",          Value = k => GridSiraYardimci.ExportSirasi(liste, k), Align = ExportAlign.Right, Width = 0.6f },
        new() { Header = "Ad",            Value = k => k.Ad,     Width = 1.2f },
        new() { Header = "Soyad",         Value = k => k.Soyad,  Width = 1.2f },
        new() { Header = "E-posta",       Value = k => k.Eposta, Width = 2f   },
        new() { Header = "Kullanıcı Tipi", Value = k => kullaniciTipler.FirstOrDefault(t => t.ID == k.KullaniciTip_ID)?.Ad ?? "-", Width = 1.4f },
        new() { Header = "Aktif",         Value = k => k.Aktif,  Align = ExportAlign.Center, Width = 0.7f },
    };
    }

    protected override async Task OnInitializedAsync()
    {
        await AuthState.InitializeAsync();
        await YetkiSvc.EnsureReadyAsync();
        if (!YetkiSvc.ErişimVar("/kullanicilar"))
        {
            Nav.NavigateTo("/erisim-engeli", true);
            return;
        }
        sadecOkuma = YetkiSvc.SadecOkuma("/kullanicilar");
        yetkiSayfasiErisim = YetkiSvc.ErişimVar("/kullanici-yetki");
        siteBaseUri = Nav.BaseUri.TrimEnd('/');
        Nav.LocationChanged += OnLocationChanged;
        await LoadAsync();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        siteBaseUri = Nav.BaseUri.TrimEnd('/');
        var path = new Uri(e.Location).AbsolutePath.TrimEnd('/');
        if (string.Equals(path, "/kullanicilar", StringComparison.OrdinalIgnoreCase))
            _ = InvokeAsync(() => LoadAsync(tamSpinner: false));
    }

    public void Dispose()
        => Nav.LocationChanged -= OnLocationChanged;

    private async Task LoadAsync(bool tamSpinner = true)
    {
        if (tamSpinner) isLoading = true;
        try
        {
            kullanicilar    = await DataSvc.GetKullanici();
            kullaniciTipler = await DataSvc.GetKullaniciTip();
        }
        finally
        {
            if (tamSpinner) isLoading = false;
        }

        await InvokeAsync(StateHasChanged);
        if (gridRef is not null)
            await gridRef.Reload();
    }

    private async Task OnYeniClick()
    {
        if (sadecOkuma) return;
        var result = await DialogSvc.OpenAsync<KullaniciTnm>("Yeni Kullanıcı",
            new Dictionary<string, object?> { { "Item", new ItemKullanicilar { Aktif = false } } },
            new DialogOptions { Width = "560px", Resizable = false, Draggable = true, CloseDialogOnOverlayClick = false });
        if (result is bool kaydedildi && kaydedildi)
            await LoadAsync(tamSpinner: false);
    }

    private void IslemlerMenuAc(MouseEventArgs args, ItemKullanicilar row)
    {
        menuSatir = row;
        var items = new List<ContextMenuItem>();
        if (row.Aktif != true)
        {
            items.Add(new()
            {
                Text = "Onay maili gönder",
                Icon = "mail",
                Value = "onay",
                Disabled = sadecOkuma || onayMailiGonderiliyorId == row.ID
            });
        }
        items.Add(new() { Text = "İncele", Icon = "visibility", Value = "incele" });
        items.Add(new() { Text = "Düzenle", Icon = "edit", Value = "duzenle", Disabled = sadecOkuma });
        items.Add(new() { Text = "Yetki Yönetimi", Icon = "shield", Value = "yetki", Disabled = !yetkiSayfasiErisim });
        items.Add(new() { Text = "Sil", Icon = "delete", Value = "sil", Disabled = sadecOkuma });
        ContextMenuSvc.Open(args, items, OnIslemMenuSecildi);
    }

    private void OnIslemMenuSecildi(MenuItemEventArgs args)
    {
        _ = InvokeAsync(async () =>
        {
            if (menuSatir is null)
                return;

            var row = menuSatir;
            menuSatir = null;

            switch (args.Value?.ToString())
            {
                case "onay":
                    await OnOnayMailiGonder(row);
                    break;
                case "incele":
                    await OnInceleClick(row);
                    break;
                case "duzenle":
                    await OnDuzenleClick(row);
                    break;
                case "yetki":
                    ContextMenuSvc.Close();
                    Nav.NavigateTo($"/kullanici-yetki/{row.ID}");
                    break;
                case "sil":
                    await OnSilClick(row);
                    break;
            }
        });
    }

    private async Task OnOnayMailiGonder(ItemKullanicilar item)
    {
        if (sadecOkuma || item.Aktif == true) return;

        var onay = await DialogSvc.Confirm(
            DialogFragments.Html(
                $"{DialogFragments.B($"{item.Ad} {item.Soyad}")} ({DialogFragments.B(item.Eposta)}) " +
                "kullanıcısına hesap onay maili gönderilsin mi?<br/><br/>" +
                "Kullanıcı bağlantıya tıklayarak hesabını onaylayacak ve geçici şifresini e-posta ile alacaktır."),
            "Onay Maili Gönder",
            new ConfirmOptions { OkButtonText = "Evet, Gönder", CancelButtonText = "İptal" });
        if (onay != true) return;

        onayMailiGonderiliyorId = item.ID;
        try
        {
            var sonuc = await DataSvc.KullaniciOnayMailiGonder(item.ID, siteBaseUri);
            if (sonuc.SonucKodu < 0)
            {
                await DialogSvc.Alert(
                    sonuc.SonucAciklama ?? "Onay maili gönderilemedi.",
                    "Mail Gönderim Başarısız",
                    new AlertOptions { OkButtonText = "Tamam" });
            }
            else
            {
                await DialogSvc.Alert(
                    DialogFragments.Html(
                        $"Onay maili {DialogFragments.B(item.Eposta)} adresine başarıyla gönderildi."),
                    "Mail Başarıyla Gönderildi",
                    new AlertOptions { OkButtonText = "Tamam" });
            }
        }
        finally
        {
            onayMailiGonderiliyorId = null;
        }
    }

    private async Task OnInceleClick(ItemKullanicilar item)
    {
        await DialogSvc.OpenAsync<KullaniciTnm>("Kullanıcı İncele",
            new Dictionary<string, object?> { { "Item", item }, { "SadeceIncele", true } },
            new DialogOptions { Width = "560px", Resizable = false, Draggable = true, CloseDialogOnOverlayClick = false });
    }

    private async Task OnDuzenleClick(ItemKullanicilar item)
    {
        if (sadecOkuma) return;
        var result = await DialogSvc.OpenAsync<KullaniciTnm>("Kullanıcı Düzenle",
            new Dictionary<string, object?> { { "Item", item } },
            new DialogOptions { Width = "560px", Resizable = false, Draggable = true, CloseDialogOnOverlayClick = false });
        if (result is bool kaydedildi && kaydedildi)
            await LoadAsync(tamSpinner: false);
    }

    private async Task OnSilClick(ItemKullanicilar item)
    {
        if (sadecOkuma) return;
        var onay = await DialogSvc.Confirm(
            DialogFragments.Html($"{DialogFragments.B($"{item.Ad} {item.Soyad}")} kullanıcısını silmek istediğinizden emin misiniz?"), "Kullanıcı Sil",
            new ConfirmOptions { OkButtonText = "Evet, Sil", CancelButtonText = "İptal" });
        if (onay != true) return;

        int userId = AuthState.CurrentUser?.ID ?? 0;
        var silItem = new ItemKullanicilar
        {
            ID = item.ID, KullaniciTip_ID = item.KullaniciTip_ID,
            Ad = item.Ad, Soyad = item.Soyad, Eposta = item.Eposta,
            Sifre = item.Sifre, Aktif = item.Aktif, CreUser = item.CreUser, DelUser = userId
        };
        var result = await DataSvc.SetKullanici(silItem);
        if (result.SonucKodu < 0)
            NotificationSvc.Notify(NotificationSeverity.Error, "Hata", result.SonucAciklama ?? "Silme işlemi başarısız.", 4000);
        else
        {
            NotificationSvc.Notify(NotificationSeverity.Success, "Başarılı", $"{item.Ad} {item.Soyad} silindi.", 3000);
            await LoadAsync(tamSpinner: false);
        }
    }

    private static string Initials(ItemKullanicilar u)
    {
        var a = !string.IsNullOrWhiteSpace(u.Ad) ? char.ToUpperInvariant(u.Ad[0]).ToString() : "";
        var s = !string.IsNullOrWhiteSpace(u.Soyad) ? char.ToUpperInvariant(u.Soyad[0]).ToString() : "";
        var init = a + s;
        return init.Length > 0 ? init : "?";
    }
}