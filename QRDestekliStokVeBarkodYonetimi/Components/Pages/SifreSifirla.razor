@page "/sifre-sifirla"
@layout QRDestekliStokVeBarkodYonetimi.Components.Layout.AuthLayout
@rendermode InteractiveServer

@inject SifreSifirlamaTokenService TokenSvc

<PageTitle>Yeni şifre belirle</PageTitle>

<div class="auth-card">
    <AuthCardHeader Title="Yeni şifre"
                    Subtitle="Hesabınız için yeni bir şifre seçin" />

    @if (string.IsNullOrWhiteSpace(Token))
    {
        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="auth-message auth-message--danger">@Error</div>
        }
        else
        {
            <div class="auth-message auth-message--danger">
                Geçerli bir sıfırlama bağlantısı yok. Lütfen e-postanızdaki bağlantıyı kullanın veya
                <a href="/sifremi-unuttum" style="font-weight:600; color:#0d9488;">şifre sıfırlama</a> talebinde bulunun.
            </div>
        }
        <div class="auth-card__footer">
            <a href="/login">Giriş sayfasına dön</a>
        </div>
    }
    else if (!TokenSvc.TryPeekValidToken(Token, out _))
    {
        <div class="auth-message auth-message--danger">
            Bağlantı geçersiz veya süresi dolmuş. Lütfen yeni şifre sıfırlama talebi oluşturun.
        </div>
        <div class="auth-card__footer">
            <a href="/sifremi-unuttum">Yeni bağlantı iste</a>
        </div>
    }
    else
    {
        <RadzenTemplateForm TItem="SifreSifirlaModel" Data="@model" Submit="@OnSubmitAsync">
            <div class="auth-form">
                <div class="auth-field">
                    <RadzenLabel Text="Yeni şifre" Component="YeniSifre" />
                    <TogglePasswordField @bind-Value="model.YeniSifre" @bind-Value:after="OnFormDegisti"
                                         Name="YeniSifre"
                                         Placeholder="En az 6 karakter" Disabled="@isBusy" />
                    @if (!string.IsNullOrEmpty(yeniSifreAlanHata))
                    {
                        <span class="form-field-error">@yeniSifreAlanHata</span>
                    }
                </div>

                <div class="auth-field">
                    <RadzenLabel Text="Yeni şifre (tekrar)" Component="YeniSifreTekrar" />
                    <TogglePasswordField @bind-Value="model.YeniSifreTekrar" @bind-Value:after="OnFormDegisti"
                                         Name="YeniSifreTekrar"
                                         Disabled="@isBusy" />
                    @if (!string.IsNullOrEmpty(yeniSifreTekrarAlanHata))
                    {
                        <span class="form-field-error">@yeniSifreTekrarAlanHata</span>
                    }
                </div>

                @if (!string.IsNullOrEmpty(sunucuHata))
                {
                    <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" AllowClose="false"
                                Style="margin-bottom:0.75rem;">@sunucuHata</RadzenAlert>
                }

                <RadzenButton ButtonType="ButtonType.Submit" Text="Şifreyi kaydet" Icon="check"
                              ButtonStyle="ButtonStyle.Primary"
                              IsBusy="@isBusy" BusyText="Kaydediliyor…"
                              Disabled="@(!SifreSifirlaFormuGecerli || isBusy)" />
            </div>
        </RadzenTemplateForm>

        <div class="auth-card__footer">
            <a href="/login">Giriş sayfasına dön</a>
        </div>
    }
</div>

@code {
    private sealed class SifreSifirlaModel
    {
        public string YeniSifre { get; set; } = string.Empty;
        public string YeniSifreTekrar { get; set; } = string.Empty;
    }

    [SupplyParameterFromQuery] public string? Token { get; set; }
    [SupplyParameterFromQuery] public string? Error { get; set; }

    private SifreSifirlaModel model = new();
    private bool isBusy;
    private string? sunucuHata;
    private string? yeniSifreAlanHata;
    private string? yeniSifreTekrarAlanHata;
    private bool formEtkilesildi;

    private bool SifreSifirlaFormuGecerli =>
        !string.IsNullOrWhiteSpace(model.YeniSifre) &&
        model.YeniSifre.Length >= 6 &&
        !string.IsNullOrWhiteSpace(model.YeniSifreTekrar) &&
        string.Equals(model.YeniSifre, model.YeniSifreTekrar, StringComparison.Ordinal) &&
        string.IsNullOrEmpty(yeniSifreAlanHata) &&
        string.IsNullOrEmpty(yeniSifreTekrarAlanHata);

    private void OnFormDegisti()
    {
        formEtkilesildi = true;
        GuncelleAlanHatalari();
    }

    private void GuncelleAlanHatalari()
    {
        if (!formEtkilesildi)
        {
            yeniSifreAlanHata = null;
            yeniSifreTekrarAlanHata = null;
            return;
        }

        if (string.IsNullOrWhiteSpace(model.YeniSifre))
            yeniSifreAlanHata = "Şifre zorunludur.";
        else if (model.YeniSifre.Length < 6)
            yeniSifreAlanHata = "Şifre en az 6 karakter olmalıdır.";
        else
            yeniSifreAlanHata = null;

        if (string.IsNullOrWhiteSpace(model.YeniSifreTekrar))
            yeniSifreTekrarAlanHata = "Tekrar şifre zorunludur.";
        else if (!string.Equals(model.YeniSifre, model.YeniSifreTekrar, StringComparison.Ordinal))
            yeniSifreTekrarAlanHata = "Şifreler eşleşmiyor.";
        else
            yeniSifreTekrarAlanHata = null;
    }

    private async Task OnSubmitAsync()
    {
        sunucuHata = null;
        formEtkilesildi = true;
        GuncelleAlanHatalari();
        if (!SifreSifirlaFormuGecerli)
            return;

        if (string.IsNullOrWhiteSpace(Token) || !TokenSvc.TryPeekValidToken(Token, out var userId))
        {
            sunucuHata = "Bağlantı geçersiz veya süresi dolmuş. Lütfen yeni şifre sıfırlama talebi oluşturun.";
            return;
        }

        isBusy = true;
        try
        {
            var result = await DataSvc.SifreSifirlaTokenIle(userId, model.YeniSifre);
            if (result.SonucKodu < 0)
            {
                sunucuHata = string.IsNullOrEmpty(result.SonucAciklama)
                    ? "Şifre güncellenemedi."
                    : result.SonucAciklama;
                return;
            }

            TokenSvc.TryConsume(Token, out _);
            NavigationManager.NavigateTo("/login?sifirlandi=1");
        }
        catch (Exception ex)
        {
            sunucuHata = "Beklenmeyen hata: " + ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }
}
