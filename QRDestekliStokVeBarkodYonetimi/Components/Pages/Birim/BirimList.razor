@page "/birimler"
@layout QRDestekliStokVeBarkodYonetimi.Components.Layout.MainLayout
@rendermode InteractiveServer

@implements IDisposable

@inject YetkiService YetkiSvc
@inject NavigationManager Nav

<PageTitle>Birimler</PageTitle>

<div class="page-header">
    <h3 class="page-header-title">Birim Listesi</h3>
    <div class="page-header-actions">
        <ExportButton TItem="ItemBirim"
                      Items="@birimler"
                      Title="Birim Listesi"
                      FileName="birim-listesi"
                      Columns="@CiktiKolonlari()" />
        <RadzenButton Text="Yeni Birim" Icon="add" ButtonStyle="ButtonStyle.Primary"
                      Click="@OnYeniClick"
                      Disabled="@sadecOkuma"
                      Style="@(sadecOkuma ? "opacity:0.35;pointer-events:none;" : "")" />
    </div>
</div>

@if (isLoading)
{
    <div style="display:flex; justify-content:center; padding:2rem;">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                   Size="ProgressBarCircularSize.Large" />
    </div>
}
else
{
    <RadzenDataGrid @ref="gridRef" Data="@filtreliBirimler" TItem="ItemBirim" AllowSorting="true"
                    AllowFiltering="true" FilterMode="FilterMode.Simple"
                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                    AllowPaging="false" AllowVirtualization="true" PageSize="25"
                    VirtualizationOverscanCount="3"
                    AllowColumnReorder="true"
                    EmptyText="Kayıt bulunamadı."
                    ColumnWidth="200px"
                    class="liste-grid-virtual">
        <Columns>

            <RadzenDataGridColumn TItem="ItemBirim" Property="ID" Title="Sıra" Width="@GridSiraYardimci.KolonGenisligi" MinWidth="@GridSiraYardimci.KolonGenisligi"
                                  Frozen="true" Filterable="false" Reorderable="false"
                                  SortComparer="@GridSiraYardimci.SiralamaIndeksiComparer(filtreliBirimler)"
                                  TextAlign="TextAlign.Center" CssClass="grid-sira-kolon">
                <Template Context="row">
                    @GridSiraYardimci.ListeSirasi(filtreliBirimler, row)
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="ItemBirim" Property="Ad" Title="Birim Adı"
                                  MinWidth="200px" />

            <RadzenDataGridColumn TItem="ItemBirim" Property="Aktif" Title="Aktif"
                                  Width="90px" TextAlign="TextAlign.Center">
                <Template Context="row">
                    <RadzenIcon Icon="@(row.Aktif ? "check_circle" : "cancel")"
                                Style="@(row.Aktif ? "color:#2e7d32" : "color:#c62828")" />
                </Template>
                <FilterTemplate>
                    <GridBoolFilter @bind-Value="@aktifFiltre" />
                </FilterTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="ItemBirim" Title="" Width="48px" TextAlign="TextAlign.Center"
                                  Sortable="false" Filterable="false" Reorderable="false">
                <Template Context="row">
                    <GridIslemMenuButonu Click="@(e => IslemlerMenuAc(e, row))" />
                </Template>
            </RadzenDataGridColumn>

        </Columns>
    </RadzenDataGrid>
}

@code {
    private RadzenDataGrid<ItemBirim>? gridRef;
    private ItemBirim[] birimler = [];
    private bool isLoading = true;
    private bool sadecOkuma = false;
    private bool? aktifFiltre;
    private ItemBirim? menuSatir;

    private ItemBirim[] filtreliBirimler => birimler.Where(b =>
        GridFilterHelper.BoolEslesir(b.Aktif, aktifFiltre)).ToArray();

    private IList<ExportColumn<ItemBirim>> CiktiKolonlari()
    {
        var liste = birimler.ToList();
        return new List<ExportColumn<ItemBirim>>
    {
        new() { Header = "Sıra",      Value = b => GridSiraYardimci.ExportSirasi(liste, b), Align = ExportAlign.Right, Width = 0.6f },
        new() { Header = "Birim Adı", Value = b => b.Ad,    Width = 2f   },
        new() { Header = "Aktif",     Value = b => b.Aktif, Align = ExportAlign.Center, Width = 0.7f },
    };
    }

    protected override async Task OnInitializedAsync()
    {
        await AuthState.InitializeAsync();
        await YetkiSvc.EnsureReadyAsync();
        if (!YetkiSvc.ErişimVar("/birimler"))
        {
            Nav.NavigateTo("/erisim-engeli", true);
            return;
        }
        sadecOkuma = YetkiSvc.SadecOkuma("/birimler");
        Nav.LocationChanged += OnLocationChanged;
        await LoadAsync();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var path = new Uri(e.Location).AbsolutePath.TrimEnd('/');
        if (string.Equals(path, "/birimler", StringComparison.OrdinalIgnoreCase))
            _ = InvokeAsync(() => LoadAsync(tamSpinner: false));
    }

    public void Dispose()
        => Nav.LocationChanged -= OnLocationChanged;

    private async Task LoadAsync(bool tamSpinner = true)
    {
        if (tamSpinner) isLoading = true;
        try { birimler = await DataSvc.GetBirim(); }
        finally { if (tamSpinner) isLoading = false; }

        await InvokeAsync(StateHasChanged);
        if (gridRef is not null)
            await gridRef.Reload();
    }

    private async Task OnYeniClick()
    {
        if (sadecOkuma) return;
        var result = await DialogSvc.OpenAsync<BirimTnm>("Yeni Birim",
            new Dictionary<string, object?> { { "Item", new ItemBirim { Aktif = true } } },
            new DialogOptions { Width = "480px", Resizable = false, Draggable = true, CloseDialogOnOverlayClick = false });
        if (result is bool kaydedildi && kaydedildi)
            await LoadAsync(tamSpinner: false);
    }

    private void IslemlerMenuAc(MouseEventArgs args, ItemBirim row)
    {
        menuSatir = row;
        ContextMenuSvc.Open(args,
            new List<ContextMenuItem>
            {
                new() { Text = "İncele", Icon = "visibility", Value = "incele" },
                new() { Text = "Düzenle", Icon = "edit", Value = "duzenle", Disabled = sadecOkuma },
                new() { Text = "Sil", Icon = "delete", Value = "sil", Disabled = sadecOkuma }
            },
            OnIslemMenuSecildi);
    }

    private void OnIslemMenuSecildi(MenuItemEventArgs args)
    {
        _ = InvokeAsync(async () =>
        {
            if (menuSatir is null)
                return;

            var row = menuSatir;
            menuSatir = null;

            switch (args.Value?.ToString())
            {
                case "incele":
                    await OnInceleClick(row);
                    break;
                case "duzenle":
                    await OnDuzenleClick(row);
                    break;
                case "sil":
                    await OnSilClick(row);
                    break;
            }
        });
    }

    private async Task OnInceleClick(ItemBirim item)
    {
        await DialogSvc.OpenAsync<BirimTnm>("Birim İncele",
            new Dictionary<string, object?> { { "Item", item }, { "SadeceIncele", true } },
            new DialogOptions { Width = "500px", Resizable = false, Draggable = true, CloseDialogOnOverlayClick = false });
    }

    private async Task OnDuzenleClick(ItemBirim item)
    {
        if (sadecOkuma) return;
        var result = await DialogSvc.OpenAsync<BirimTnm>("Birim Düzenle",
            new Dictionary<string, object?> { { "Item", item } },
            new DialogOptions { Width = "480px", Resizable = false, Draggable = true, CloseDialogOnOverlayClick = false });
        if (result is bool kaydedildi && kaydedildi)
            await LoadAsync(tamSpinner: false);
    }

    private async Task OnSilClick(ItemBirim item)
    {
        if (sadecOkuma) return;
        var onay = await DialogSvc.Confirm(
            DialogFragments.Html($"{DialogFragments.B(item.Ad)} birimini silmek istediğinizden emin misiniz?"), "Birim Sil",
            new ConfirmOptions { OkButtonText = "Evet, Sil", CancelButtonText = "İptal" });
        if (onay != true) return;

        int userId = AuthState.CurrentUser?.ID ?? 0;
        var silItem = new ItemBirim { ID = item.ID, Ad = item.Ad, Aktif = item.Aktif, CreUser = item.CreUser, DelUser = userId };
        var result = await DataSvc.SetBirim(silItem);

        if (result.SonucKodu < 0)
            NotificationSvc.Notify(NotificationSeverity.Error, "Hata", result.SonucAciklama ?? "Silme işlemi başarısız.", 4000);
        else
        {
            NotificationSvc.Notify(NotificationSeverity.Success, "Başarılı", $"{item.Ad} silindi.", 3000);
            await LoadAsync(tamSpinner: false);
        }
    }
}