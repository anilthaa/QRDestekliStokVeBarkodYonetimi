@page "/birimler"
@layout QRDestekliStokVeBarkodYonetimi.Components.Layout.MainLayout
@rendermode InteractiveServer

@inject YetkiService YetkiSvc
@inject NavigationManager Nav

<PageTitle>Birimler</PageTitle>

<div class="page-header">
    <h3 class="page-header-title">Birim Listesi</h3>
    <div class="page-header-actions">
        <ExportButton TItem="ItemBirim"
                      Items="@birimler"
                      Title="Birim Listesi"
                      FileName="birim-listesi"
                      Columns="@CiktiKolonlari()" />
        <RadzenButton Text="Yeni Birim" Icon="add" ButtonStyle="ButtonStyle.Primary"
                      Click="@OnYeniClick"
                      Disabled="@sadecOkuma"
                      Style="@(sadecOkuma ? "opacity:0.35;pointer-events:none;" : "")" />
    </div>
</div>

@if (isLoading)
{
    <div style="display:flex; justify-content:center; padding:2rem;">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                   Size="ProgressBarCircularSize.Large" />
    </div>
}
else
{
    <RadzenDataGrid Data="@filtreliBirimler" TItem="ItemBirim" AllowSorting="true"
                    AllowFiltering="true" FilterMode="FilterMode.Simple"
                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                    AllowPaging="true" PageSize="15"
                    EmptyText="Kayıt bulunamadı."
                    ColumnWidth="200px">
        <Columns>

            <RadzenDataGridColumn TItem="ItemBirim" Property="ID" Title="ID"
                                  Width="70px" Frozen="true">
                <FilterTemplate>
                    <GridTextFilter @bind-Value="@idFiltre" />
                </FilterTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="ItemBirim" Property="Ad" Title="Birim Adı"
                                  MinWidth="200px" />

            <RadzenDataGridColumn TItem="ItemBirim" Property="Aktif" Title="Aktif"
                                  Width="90px" TextAlign="TextAlign.Center">
                <Template Context="row">
                    <RadzenIcon Icon="@(row.Aktif ? "check_circle" : "cancel")"
                                Style="@(row.Aktif ? "color:#2e7d32" : "color:#c62828")" />
                </Template>
                <FilterTemplate>
                    <GridBoolFilter @bind-Value="@aktifFiltre" />
                </FilterTemplate>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="ItemBirim" Title="İşlemler"
                                  Width="120px" TextAlign="TextAlign.Center"
                                  Sortable="false" Filterable="false">
                <Template Context="row">
                    <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Info" Size="ButtonSize.Small"
                                  Variant="Variant.Flat"
                                  Click="@(() => OnDuzenleClick(row))"
                                  Disabled="@sadecOkuma"
                                  Style="@("margin-right:4px;" + (sadecOkuma ? "opacity:0.35;pointer-events:none;" : ""))"
                                  title="Düzenle" />
                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                  Variant="Variant.Flat"
                                  Click="@(() => OnSilClick(row))"
                                  Disabled="@sadecOkuma"
                                  Style="@(sadecOkuma ? "opacity:0.35;pointer-events:none;" : "")"
                                  title="Sil" />
                </Template>
            </RadzenDataGridColumn>

        </Columns>
    </RadzenDataGrid>
}

@code {
    private ItemBirim[] birimler = [];
    private bool isLoading = true;
    private bool sadecOkuma = false;
    private string? idFiltre;
    private bool? aktifFiltre;

    private ItemBirim[] filtreliBirimler => birimler.Where(b =>
        GridFilterHelper.Eslesir(b.ID, idFiltre) &&
        GridFilterHelper.BoolEslesir(b.Aktif, aktifFiltre)).ToArray();

    private IList<ExportColumn<ItemBirim>> CiktiKolonlari() => new List<ExportColumn<ItemBirim>>
    {
        new() { Header = "ID",        Value = b => b.ID,    Align = ExportAlign.Right, Width = 0.6f },
        new() { Header = "Birim Adı", Value = b => b.Ad,    Width = 2f   },
        new() { Header = "Aktif",     Value = b => b.Aktif, Align = ExportAlign.Center, Width = 0.7f },
    };

    protected override async Task OnInitializedAsync()
    {
        await AuthState.InitializeAsync();
        await YetkiSvc.EnsureReadyAsync();
        if (!YetkiSvc.ErişimVar("/birimler"))
        {
            Nav.NavigateTo("/erisim-engeli", true);
            return;
        }
        sadecOkuma = YetkiSvc.SadecOkuma("/birimler");
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        try { birimler = await DataSvc.GetBirim(); }
        finally { isLoading = false; }
    }

    private async Task OnYeniClick()
    {
        if (sadecOkuma) return;
        var result = await DialogSvc.OpenAsync<BirimTnm>("Yeni Birim",
            new Dictionary<string, object?> { { "Item", new ItemBirim { Aktif = true } } },
            new DialogOptions { Width = "480px", Resizable = false, Draggable = true, CloseDialogOnOverlayClick = false });
        if (result is true) await LoadAsync();
    }

    private async Task OnDuzenleClick(ItemBirim item)
    {
        if (sadecOkuma) return;
        var result = await DialogSvc.OpenAsync<BirimTnm>("Birim Düzenle",
            new Dictionary<string, object?> { { "Item", item } },
            new DialogOptions { Width = "480px", Resizable = false, Draggable = true, CloseDialogOnOverlayClick = false });
        if (result is true) await LoadAsync();
    }

    private async Task OnSilClick(ItemBirim item)
    {
        if (sadecOkuma) return;
        var onay = await DialogSvc.Confirm(
            DialogFragments.Html($"{DialogFragments.B(item.Ad)} birimini silmek istediğinizden emin misiniz?"), "Birim Sil",
            new ConfirmOptions { OkButtonText = "Evet, Sil", CancelButtonText = "İptal" });
        if (onay != true) return;

        int userId = AuthState.CurrentUser?.ID ?? 0;
        var silItem = new ItemBirim { ID = item.ID, Ad = item.Ad, Aktif = item.Aktif, CreUser = item.CreUser, DelUser = userId };
        var result = await DataSvc.SetBirim(silItem);

        if (result.SonucKodu < 0)
            NotificationSvc.Notify(NotificationSeverity.Error, "Hata", result.SonucAciklama ?? "Silme işlemi başarısız.", 4000);
        else
        {
            NotificationSvc.Notify(NotificationSeverity.Success, "Başarılı", $"{item.Ad} silindi.", 3000);
            await LoadAsync();
        }
    }
}