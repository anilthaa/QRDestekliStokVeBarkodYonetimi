@page "/register"
@layout QRDestekliStokVeBarkodYonetimi.Components.Layout.AuthLayout

@* @rendermode bilerek YOK — form-post için static SSR. *@

<PageTitle>Kayıt Ol</PageTitle>

<div class="auth-card">
    <div class="auth-card__brand">
        <i class="fa-solid fa-user-plus" style="font-size:2.4rem;color:#1b6ec2;"></i>
        <h1>Yeni Hesap Oluştur</h1>
        <p>Stok yönetim paneline erişmek için kaydolun</p>
    </div>

    <form method="post" action="/api/auth/register" class="auth-form">
        <div class="auth-row" style="display:grid; grid-template-columns:1fr 1fr; gap:0.5rem;">
            <div class="auth-field">
                <label class="rz-label" for="Ad">Ad</label>
                <input id="Ad" name="Ad" type="text" required class="rz-textbox" style="width:100%;" />
            </div>

            <div class="auth-field">
                <label class="rz-label" for="Soyad">Soyad</label>
                <input id="Soyad" name="Soyad" type="text" required class="rz-textbox" style="width:100%;" />
            </div>
        </div>

        <div class="auth-field">
            <label class="rz-label" for="Eposta">E-posta</label>
            <input id="Eposta" name="Eposta" type="email" required
                   placeholder="ornek@mail.com"
                   class="rz-textbox" style="width:100%;" />
        </div>

        <div class="auth-field">
            <label class="rz-label" for="Sifre">Şifre</label>
            <input id="Sifre" name="Sifre" type="password" required minlength="6"
                   placeholder="En az 6 karakter"
                   class="rz-textbox" style="width:100%;" />
        </div>

        <div class="auth-field">
            <label class="rz-label" for="SifreTekrar">Şifre (Tekrar)</label>
            <input id="SifreTekrar" name="SifreTekrar" type="password" required minlength="6"
                   class="rz-textbox" style="width:100%;" />
        </div>

        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="rz-alert rz-alert-danger" style="margin-bottom:0.75rem;">@Error</div>
        }

        <button type="submit" class="rz-button rz-button-md rz-button-primary"
                style="width:100%; margin-top:0.25rem;">
            <span class="rz-button-icon-left">
                <i class="fa-solid fa-user-check"></i>
            </span>
            <span class="rz-button-text">Kayıt Ol</span>
        </button>
    </form>

    <div class="auth-card__footer">
        Zaten hesabınız var mı? <a href="/login">Giriş yapın</a>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
}
