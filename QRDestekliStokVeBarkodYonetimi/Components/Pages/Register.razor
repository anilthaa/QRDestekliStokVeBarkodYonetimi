@page "/register"
@layout QRDestekliStokVeBarkodYonetimi.Components.Layout.AuthLayout
@rendermode InteractiveServer

<PageTitle>Kayıt Ol</PageTitle>

<div class="auth-card auth-card--wide">
    <AuthCardHeader Title="Yeni Hesap Oluştur"
                    Subtitle="Stok yönetim paneline erişmek için kaydolun" />

    <RadzenTemplateForm TItem="RegisterModel" Data="@model" Submit="@OnSubmitAsync" InvalidSubmit="@OnInvalidSubmit">
        <div class="auth-form">
            <div class="auth-row">
                <div class="auth-field">
                    <RadzenLabel Text="Ad *" Component="Ad" />
                    <RadzenTextBox @bind-Value="model.Ad" Name="Ad" Style="width:100%;" Disabled="@kayitIsBusy" />
                    <RadzenRequiredValidator Component="Ad" Text="Ad zorunludur." Style="display:block" />
                </div>

                <div class="auth-field">
                    <RadzenLabel Text="Soyad *" Component="Soyad" />
                    <RadzenTextBox @bind-Value="model.Soyad" Name="Soyad" Style="width:100%;" Disabled="@kayitIsBusy" />
                    <RadzenRequiredValidator Component="Soyad" Text="Soyad zorunludur." Style="display:block" />
                </div>
            </div>

            <div class="auth-field">
                <RadzenLabel Text="E-posta *" Component="Eposta" />
                <RadzenTextBox @bind-Value="model.Eposta" Name="Eposta"
                               Placeholder="ornek@mail.com"
                               Style="width:100%;" Disabled="@kayitIsBusy" />
                <RadzenRequiredValidator Component="Eposta" Text="E-posta zorunludur." Style="display:block" />
                <RadzenEmailValidator Component="Eposta" Text="Geçerli bir e-posta giriniz." Style="display:block" />
            </div>

            <div class="auth-field">
                <RadzenLabel Text="Şifre *" Component="Sifre" />
                <TogglePasswordField @bind-Value="model.Sifre" @bind-Value:after="OnFormDegisti"
                                     Name="Sifre"
                                     HatalariGoster="@hatalariGoster"
                                     Placeholder="En az 6 karakter" Disabled="@kayitIsBusy" />
                @if (!string.IsNullOrEmpty(sifreAlanHata))
                {
                    <span class="form-field-error">@sifreAlanHata</span>
                }
            </div>

            <div class="auth-field">
                <RadzenLabel Text="Şifre (Tekrar) *" Component="SifreTekrar" />
                <TogglePasswordField @bind-Value="model.SifreTekrar" @bind-Value:after="OnFormDegisti"
                                     Name="SifreTekrar"
                                     HatalariGoster="@hatalariGoster"
                                     Disabled="@kayitIsBusy" />
                @if (!string.IsNullOrEmpty(sifreTekrarAlanHata))
                {
                    <span class="form-field-error">@sifreTekrarAlanHata</span>
                }
            </div>

            @if (!string.IsNullOrEmpty(kayitHata))
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" AllowClose="false"
                            Style="margin-bottom:0.75rem;">@kayitHata</RadzenAlert>
            }

            <RadzenButton ButtonType="ButtonType.Submit" Text="Kayıt ol" Icon="person_add"
                          ButtonStyle="ButtonStyle.Primary"
                          IsBusy="@kayitIsBusy" BusyText="Kaydediliyor…"
                          Disabled="@(!RegisterFormuGecerli || kayitIsBusy)" />
        </div>
    </RadzenTemplateForm>

    <div class="auth-card__footer">
        Zaten hesabınız var mı? <a href="/login">Giriş yapın</a>
    </div>
</div>

@code {
    private sealed class RegisterModel
    {
        public string Ad { get; set; } = string.Empty;
        public string Soyad { get; set; } = string.Empty;
        public string Eposta { get; set; } = string.Empty;
        public string Sifre { get; set; } = string.Empty;
        public string SifreTekrar { get; set; } = string.Empty;
    }

    [SupplyParameterFromQuery] public string? Error { get; set; }

    private RegisterModel model = new();
    private string kayitHata = string.Empty;
    private bool kayitIsBusy;
    private bool hatalariGoster;
    private bool formEtkilesildi;
    private string? sifreAlanHata;
    private string? sifreTekrarAlanHata;

    private bool RegisterFormuGecerli =>
        !string.IsNullOrWhiteSpace(model.Ad) &&
        !string.IsNullOrWhiteSpace(model.Soyad) &&
        !string.IsNullOrWhiteSpace(model.Eposta) &&
        !string.IsNullOrWhiteSpace(model.Sifre) &&
        model.Sifre.Length >= 6 &&
        !string.IsNullOrWhiteSpace(model.SifreTekrar) &&
        string.Equals(model.Sifre, model.SifreTekrar, StringComparison.Ordinal) &&
        string.IsNullOrEmpty(sifreAlanHata) &&
        string.IsNullOrEmpty(sifreTekrarAlanHata);

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(Error))
            kayitHata = Error;
    }

    private void OnInvalidSubmit()
    {
        hatalariGoster = true;
        formEtkilesildi = true;
        GuncelleAlanHatalari();
    }

    private void OnFormDegisti()
    {
        formEtkilesildi = true;
        GuncelleAlanHatalari();
    }

    private void GuncelleAlanHatalari()
    {
        if (!formEtkilesildi)
        {
            sifreAlanHata = null;
            sifreTekrarAlanHata = null;
            return;
        }

        if (string.IsNullOrWhiteSpace(model.Sifre))
            sifreAlanHata = "Şifre zorunludur.";
        else if (model.Sifre.Length < 6)
            sifreAlanHata = "Şifre en az 6 karakter olmalıdır.";
        else
            sifreAlanHata = null;

        if (string.IsNullOrWhiteSpace(model.SifreTekrar))
            sifreTekrarAlanHata = "Tekrar şifre zorunludur.";
        else if (!string.Equals(model.Sifre, model.SifreTekrar, StringComparison.Ordinal))
            sifreTekrarAlanHata = "Şifreler eşleşmiyor.";
        else
            sifreTekrarAlanHata = null;
    }

    private async Task OnSubmitAsync()
    {
        kayitHata = string.Empty;
        hatalariGoster = true;
        formEtkilesildi = true;
        GuncelleAlanHatalari();
        if (!RegisterFormuGecerli)
            return;

        kayitIsBusy = true;
        try
        {
            var sonuc = await DataSvc.RegisterKullanici(
                model.Ad.Trim(),
                model.Soyad.Trim(),
                model.Eposta.Trim(),
                model.Sifre);

            if (sonuc.SonucKodu < 0 || sonuc.Data <= 0)
            {
                kayitHata = string.IsNullOrEmpty(sonuc.SonucAciklama)
                    ? "Kayıt sırasında bir hata oluştu."
                    : sonuc.SonucAciklama;
                return;
            }

            NavigationManager.NavigateTo("/login?registered=1");
        }
        catch (Exception ex)
        {
            kayitHata = "Kayıt sırasında beklenmeyen bir hata oluştu: " + ex.Message;
        }
        finally
        {
            kayitIsBusy = false;
        }
    }
}
