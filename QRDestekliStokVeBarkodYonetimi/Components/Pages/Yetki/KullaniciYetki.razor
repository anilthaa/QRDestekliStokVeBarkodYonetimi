@page "/kullanici-yetki/{KullaniciId:int}"
@layout QRDestekliStokVeBarkodYonetimi.Components.Layout.MainLayout
@rendermode InteractiveServer

@inject DataService DataSvc
@inject AuthStateService AuthState
@inject YetkiService YetkiSvc
@inject NavigationManager Nav
@inject NotificationService NotifSvc

<PageTitle>Kullanıcı Yetki Yönetimi</PageTitle>

@if (!authChecked)
{
    <div style="display:flex; justify-content:center; align-items:center; height:60vh;">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Large" />
    </div>
}
else
{
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem; flex-wrap:wrap; gap:0.5rem;">
        <h4 style="margin:0;">
            <i class="fa-solid fa-user-shield" style="color:#1976d2; margin-right:0.5rem;"></i>
            @if (kullanici is not null)
            {
                <span>@kullanici.Ad @kullanici.Soyad — Yetki Yönetimi</span>
            }
            else
            {
                <span>Kullanıcı Yetki Yönetimi</span>
            }
        </h4>
        <RadzenButton Text="Geri Dön" Icon="arrow_back" ButtonStyle="ButtonStyle.Light"
                      Click="@(() => Nav.NavigateTo("/kullanicilar"))" />
    </div>

    @if (kullanici is null)
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true">Kullanıcı bulunamadı.</RadzenAlert>
    }
    else
    {
        <RadzenCard>
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
                <h6 style="margin:0;">Form Yetkileri</h6>
                @if (yukleniyor)
                {
                    <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
                }
            </div>

            <p style="font-size:0.82rem; color:#888; margin:0 0 1rem;">
                <strong>Tip Yetkisi (Kalıtım):</strong> Kullanıcıya özel override kaldırılır; bu sayfanın yetkisi kullanıcı tipinden kalıtılır.<br />
                <strong>Gizli:</strong> Kullanıcı, tip yetkisi Yazma olsa bile bu sayfayı göremez ve erişemez.<br />
                <strong>Okuma / Yazma:</strong> Kullanıcıya özel yetki, tip yetkisini geçersiz kılar.
            </p>

            <table style="width:100%; border-collapse:collapse; font-size:0.9rem;">
                <thead>
                    <tr style="background:#f5f5f5; font-weight:600;">
                        <th style="padding:0.5rem 0.75rem; text-align:left; border-bottom:2px solid #e0e0e0;">Form / Sayfa</th>
                        <th style="padding:0.5rem; text-align:center; border-bottom:2px solid #e0e0e0; width:110px; color:#888;">Tip Yetkisi</th>
                        <th style="padding:0.5rem; text-align:center; border-bottom:2px solid #e0e0e0; width:90px; color:#c62828;">Gizli</th>
                        <th style="padding:0.5rem; text-align:center; border-bottom:2px solid #e0e0e0; width:90px; color:#1976d2;">Okuma</th>
                        <th style="padding:0.5rem; text-align:center; border-bottom:2px solid #e0e0e0; width:90px; color:#2e7d32;">Yazma</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var f in tumFormlar)
                    {
                        @* yetkiMap[f.ID] null → override yok, tip yetkisi geçerli *@
                        var override_ = yetkiMap.TryGetValue(f.ID, out var ov) ? ov : null;

                        <tr style="border-bottom:1px solid #f0f0f0; @(override_.HasValue ? "background:#fffde7;" : "")">
                            <td style="padding:0.45rem 0.75rem;">
                                @if (!string.IsNullOrWhiteSpace(f.Icon))
                                {
                                    <i class="@f.Icon" style="margin-right:0.4rem; color:#666;"></i>
                                }
                                @f.Ad
                                @if (f.UstMenu_ID.HasValue)
                                {
                                    <span style="font-size:0.75rem; color:#bbb; margin-left:0.4rem;">(alt)</span>
                                }
                                @if (override_.HasValue)
                                {
                                    <span style="font-size:0.72rem; color:#f57c00; margin-left:0.5rem; font-weight:600;">● özel</span>
                                }
                            </td>
                            @* Tip Yetkisine Dön (KalitimYok = -1) *@
                            <td style="text-align:center; padding:0.45rem;">
                                <input type="radio" name="yetki_@f.ID"
                                       checked="@(!override_.HasValue)"
                                       @onchange="@(() => YetkiDegistir(f.ID, YetkiTipi.KalitimYok))" />
                            </td>
                            @* Gizli (0) *@
                            <td style="text-align:center; padding:0.45rem;">
                                <input type="radio" name="yetki_@f.ID"
                                       checked="@(override_ == YetkiTipi.Gizli)"
                                       @onchange="@(() => YetkiDegistir(f.ID, YetkiTipi.Gizli))" />
                            </td>
                            @* Okuma (1) *@
                            <td style="text-align:center; padding:0.45rem;">
                                <input type="radio" name="yetki_@f.ID"
                                       checked="@(override_ == YetkiTipi.Okuma)"
                                       @onchange="@(() => YetkiDegistir(f.ID, YetkiTipi.Okuma))" />
                            </td>
                            @* Yazma (2) *@
                            <td style="text-align:center; padding:0.45rem;">
                                <input type="radio" name="yetki_@f.ID"
                                       checked="@(override_ == YetkiTipi.Yazma)"
                                       @onchange="@(() => YetkiDegistir(f.ID, YetkiTipi.Yazma))" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </RadzenCard>
    }
}

@code {
    [Parameter] public int KullaniciId { get; set; }

    private bool authChecked = false;
    private bool yukleniyor  = false;

    private ItemKullanicilar?   kullanici    = null;
    private ItemForm[]          tumFormlar   = [];

    /// <summary>
    /// Form ID → kullanıcıya özel override yetki değeri.
    /// null  = override yok, tip yetkisi kalıtılır.
    /// 0/1/2 = Gizli / Okuma / Yazma override kaydı.
    /// </summary>
    private Dictionary<int, int?> yetkiMap = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthState.InitializeAsync();
            if (!AuthState.IsAuthenticated)
            {
                Nav.NavigateTo("/login", replace: true);
                return;
            }
            authChecked = true;
            await LoadAsync();
            StateHasChanged();
        }
    }

    private async Task LoadAsync()
    {
        yukleniyor = true;
        tumFormlar = await DataSvc.GetTumFormlar();
        kullanici  = (await DataSvc.GetKullanici(KullaniciId)).FirstOrDefault();

        if (kullanici is not null)
        {
            // Yalnızca kullanıcıya özel override kayıtlarını yükle.
            // Override yoksa map'te girdi olmaz → null (kalıtım).
            var yetkiler = await DataSvc.GetKullaniciFormYetki(KullaniciId);
            yetkiMap = yetkiler.ToDictionary(y => y.Form_ID, y => (int?)y.Yetki);
        }
        yukleniyor = false;
    }

    private async Task YetkiDegistir(int formId, int yeniYetki)
    {
        // UI state'i optimistik güncelle
        if (yeniYetki == YetkiTipi.KalitimYok)
            yetkiMap.Remove(formId);   // override kaldır → null (kalıtım)
        else
            yetkiMap[formId] = yeniYetki;

        try
        {
            // yeniYetki = -1 → DataService kaydı soft-delete eder (tip yetkisine döner)
            // yeniYetki >= 0 → override kaydı yazar (Gizli=0 dahil)
            await DataSvc.SetKullaniciFormYetki(
                KullaniciId, formId, yeniYetki,
                AuthState.CurrentUser?.ID ?? 1);

            // Yetki haritası önbelleğini zorla yenile.
            // Düzenlenen kullanıcı aktif kullanıcının kendisiyse NavMenu anında güncellenir.
            await YetkiSvc.ForceReloadAsync(KullaniciId);

            NotifSvc.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary  = "Kaydedildi",
                Duration = 1500
            });
        }
        catch (Exception ex)
        {
            // Hata durumunda UI state'i geri al
            await LoadAsync();

            NotifSvc.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary  = "Hata",
                Detail   = ex.Message,
                Duration = 3000
            });
        }

        StateHasChanged();
    }
}
