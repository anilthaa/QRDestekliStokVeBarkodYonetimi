@page "/stok-giris"
@layout QRDestekliStokVeBarkodYonetimi.Components.Layout.MainLayout
@rendermode InteractiveServer

@inject YetkiService YetkiSvc
@inject NavigationManager Nav

<PageTitle>Stok Giriş</PageTitle>

<h3 style="margin-bottom:1.5rem;">
    <i class="fa-solid fa-arrow-down-to-bracket" style="color:#2e7d32;"></i> Stok Giriş
</h3>

<StokBarkodTarama ReaderElementId="barkod-reader"
                  AraButtonStyle="ButtonStyle.Primary"
                  @bind-ManuelBarkod="manuelBarkod"
                  BarkodBulundu="BarkodAra" />

@if (bulunanUrun != null)
{
    <RadzenCard Style="margin-bottom:1rem; border-left:4px solid #2e7d32; padding:1rem;">
        <div class="stok-urun-kart">
            <div class="stok-urun-gorsel">
                <UrunResimSlayt ResimYolu="@bulunanUrun.ResimYolu" UrunAdi="@bulunanUrun.Ad" Kompakt="true" />
            </div>
            <div class="stok-urun-icerik">
                <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:0.5rem;">
                    <div>
                        <div style="font-size:1rem; font-weight:600;">@bulunanUrun.Ad</div>
                        <div style="font-size:0.82rem; color:#666;">Ürün Kodu: @bulunanUrun.UrunKodu</div>
                        <div style="font-size:0.82rem; color:#666;">Barkod: @bulunanUrun.BarkodNo</div>
                    </div>
                    <div style="text-align:right;">
                        <div style="font-size:0.82rem; color:#666;">Mevcut Stok</div>
                        <div style="font-size:1.4rem; font-weight:700; color:@(bulunanUrun.Stok <= bulunanUrun.KritikStokSeviyesi ? "#c62828" : "#2e7d32")">
                            @bulunanUrun.Stok @birimAdi
                        </div>
                    </div>
                </div>
                <hr style="margin:0.75rem 0;" />
                <div style="display:flex; flex-direction:column; gap:0.75rem;">
                    <div>
                        <RadzenLabel Text="@($"Giriş Miktarı ({birimAdi})")" />
                        <RadzenNumeric @bind-Value="girisAdet" TValue="decimal" Min="1" Step="1"
                                       Style="width:100%; margin-top:4px;" />
                    </div>
                    <div>
                        <RadzenLabel Text="Not (isteğe bağlı)" />
                        <RadzenTextBox @bind-Value="not" Placeholder="Açıklama..."
                                       Style="width:100%; margin-top:4px;" />
                    </div>
                    <RadzenButton Text="Stok Girişi Yap" Icon="add_circle" ButtonStyle="ButtonStyle.Success"
                                  Click="@GirisYap"
                                  Disabled="@(islemDevam || sadecOkuma)"
                                  Style="@("width:100%;" + (sadecOkuma ? "opacity:0.35;pointer-events:none;" : ""))" />
                    @if (sadecOkuma)
                    {
                        <div style="font-size:0.8rem; color:#c62828; margin-top:6px; text-align:center;">
                            <i class="fa-solid fa-lock"></i> Bu sayfada yalnızca görüntüleme yetkiniz var.
                        </div>
                    }
                </div>
            </div>
        </div>
    </RadzenCard>
}
else if (aramaTamamlandi)
{
    <RadzenAlert AlertStyle="AlertStyle.Warning">
        <i class="fa-solid fa-triangle-exclamation"></i> Barkoda ait ürün bulunamadı.
    </RadzenAlert>
}

@if (sonIslemler.Count > 0)
{
    <h5 style="margin-top:1.5rem; margin-bottom:0.5rem;">Son İşlemler</h5>
    @foreach (var log in sonIslemler)
    {
        <div style="font-size:0.84rem; padding:0.4rem 0.6rem; background:#f1f8f1; border-radius:6px; margin-bottom:4px; color:#2e7d32;">
            <i class="fa-solid fa-check"></i> @log
        </div>
    }
}

@code {
    private string manuelBarkod = string.Empty;

    private ItemUrun? bulunanUrun;
    private string birimAdi = "adet";
    private bool aramaTamamlandi = false;
    private decimal girisAdet = 1;
    private string? not;
    private bool islemDevam = false;

    private List<string> sonIslemler = new();
    private bool sadecOkuma = false;

    protected override async Task OnInitializedAsync()
    {
        await AuthState.InitializeAsync();
        await YetkiSvc.EnsureReadyAsync();
        if (!YetkiSvc.ErişimVar("/stok-giris"))
        {
            Nav.NavigateTo("/erisim-engeli", true);
            return;
        }
        sadecOkuma = YetkiSvc.SadecOkuma("/stok-giris");
    }

    private async Task BarkodAra(BarkodOkumaBildirimi okuma)
    {
        var barkod = QrSvc.BarkodNoCikar(okuma.Barkod) ?? okuma.Barkod;
        if (string.IsNullOrWhiteSpace(barkod)) return;
        bulunanUrun = null;
        birimAdi = "adet";
        aramaTamamlandi = false;
        girisAdet = 1;
        not = null;
        bulunanUrun = await DataSvc.GetUrunByBarkod(barkod);
        if (bulunanUrun != null)
        {
            var birimler = await DataSvc.GetBirim(bulunanUrun.Birim_ID);
            if (birimler.Length > 0 && !string.IsNullOrWhiteSpace(birimler[0].Ad))
                birimAdi = birimler[0].Ad.Trim();
            await BarkodBasariSesiYardimci.CalAsync(JS, okuma.Kaynak);
        }
        aramaTamamlandi = true;
        StateHasChanged();
    }

    private async Task GirisYap()
    {
        if (sadecOkuma) return;
        if (bulunanUrun == null || girisAdet <= 0) return;
        islemDevam = true;
        try
        {
            int userId = AuthState.CurrentUser?.ID ?? 0;
            var result = await DataSvc.SetStokHareketi(bulunanUrun.ID, 1, girisAdet, not, userId);
            if (result.SonucKodu < 0)
            {
                NotificationSvc.Notify(NotificationSeverity.Error, "Hata", result.SonucAciklama, 4000);
            }
            else
            {
                var urunAd = bulunanUrun.Ad;
                var birim = BirimMetni(birimAdi);
                var log = $"{DateTime.Now:HH:mm:ss} — {urunAd}: +{girisAdet:N2} {birim} giriş yapıldı.";
                sonIslemler.Insert(0, log);
                if (sonIslemler.Count > 10) sonIslemler.RemoveAt(10);
                NotificationSvc.Notify(NotificationSeverity.Success, "Başarılı",
                    $"{urunAd} için {girisAdet:N2} {birim} stok girişi yapıldı.", 3000);
                bulunanUrun = null;
                aramaTamamlandi = false;
                manuelBarkod = string.Empty;
                girisAdet = 1;
                not = null;
            }
        }
        finally { islemDevam = false; }
    }

    private static string BirimMetni(string? birim) =>
        string.IsNullOrWhiteSpace(birim) ? "adet" : birim.Trim().ToLowerInvariant();
}