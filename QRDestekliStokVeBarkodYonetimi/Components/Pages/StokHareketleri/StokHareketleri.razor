@page "/stok-hareketleri"
@layout QRDestekliStokVeBarkodYonetimi.Components.Layout.MainLayout
@rendermode InteractiveServer
@using QRDestekliStokVeBarkodYonetimi.Components.Pages.Urun

@inject YetkiService YetkiSvc
@inject NavigationManager Nav

<PageTitle>Stok Hareketleri</PageTitle>

<div class="page-header">
    <h3 class="page-header-title">Stok Hareketleri</h3>
    <div class="page-header-actions">
        <ExportButton TItem="ItemStokHareketleri"
                      Items="@filtreliHareketler"
                      Title="Stok Hareketleri"
                      FileName="stok-hareketleri"
                      Columns="@CiktiKolonlari()" />
        <RadzenButton Text="Yenile" Icon="refresh" ButtonStyle="ButtonStyle.Secondary"
                      Click="@LoadAsync" />
    </div>
</div>

<div class="filter-toolbar">
    <div>
        <RadzenLabel Text="Hareket Tipi" />
        <RadzenSelectBar @bind-Value="@filtreHareketTipi" TValue="short?" Style="margin-top:4px;">
            <Items>
                <RadzenSelectBarItem Text="Tümü" Value="@((short?)null)" />
                <RadzenSelectBarItem Text="Giriş" Value="@((short?)1)" />
                <RadzenSelectBarItem Text="Çıkış" Value="@((short?)2)" />
            </Items>
        </RadzenSelectBar>
    </div>
    <div>
        <RadzenLabel Text="Başlangıç Tarihi" />
        <RadzenDatePicker @bind-Value="@filtreBasTarih" TValue="DateTime?" DateFormat="dd.MM.yyyy"
                          Style="width:160px; display:block; margin-top:4px;" />
    </div>
    <div>
        <RadzenLabel Text="Bitiş Tarihi" />
        <RadzenDatePicker @bind-Value="@filtreBitTarih" TValue="DateTime?" DateFormat="dd.MM.yyyy"
                          Style="width:160px; display:block; margin-top:4px;" />
    </div>
    <RadzenButton Text="Filtrele" Icon="filter_alt" ButtonStyle="ButtonStyle.Primary"
                  Click="@ApplyDateFilterAsync" Style="height:36px;" />
    <RadzenButton Text="Temizle" Icon="filter_alt_off" ButtonStyle="ButtonStyle.Light"
                  Click="@ClearFilter" Style="height:36px;" />
</div>

@if (isLoading)
{
    <div style="display:flex; justify-content:center; padding:2rem;">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                   Size="ProgressBarCircularSize.Large" />
    </div>
}
else
{
    <div class="stok-hareket-stats">
        <div class="stok-hareket-stat-card">
            <RadzenCard>
                <div class="stok-hareket-stat-label">Toplam Kayıt</div>
                <div class="stok-hareket-stat-value">@filtreliHareketler.Length</div>
            </RadzenCard>
        </div>
        <div class="stok-hareket-stat-card stok-hareket-stat-card--giris">
            <RadzenCard>
                <div class="stok-hareket-stat-label">Toplam Giriş</div>
                <div class="stok-hareket-stat-value stok-hareket-stat-value--giris">
                    @filtreliHareketler.Where(x => x.HareketTipi == 1).Sum(x => x.Miktar).ToString("N2")
                </div>
            </RadzenCard>
        </div>
        <div class="stok-hareket-stat-card stok-hareket-stat-card--cikis">
            <RadzenCard>
                <div class="stok-hareket-stat-label">Toplam Çıkış</div>
                <div class="stok-hareket-stat-value stok-hareket-stat-value--cikis">
                    @filtreliHareketler.Where(x => x.HareketTipi == 2).Sum(x => x.Miktar).ToString("N2")
                </div>
            </RadzenCard>
        </div>
    </div>

    <RadzenDataGrid Data="@gridHareketler" TItem="ItemStokHareketleri"
                    AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.Simple"
                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                    AllowPaging="true" PageSize="20" EmptyText="Kayıt bulunamadı." ColumnWidth="160px">
        <Columns>
            <RadzenDataGridColumn TItem="ItemStokHareketleri" Property="ID" Title="ID" Width="70px" Frozen="true">
                <FilterTemplate>
                    <GridTextFilter @bind-Value="@idFiltre" />
                </FilterTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ItemStokHareketleri" Title="Resim" Width="72px" TextAlign="TextAlign.Center"
                                  Sortable="false" Filterable="false">
                <Template Context="row">
                    @{
                        var thumb = IlkResimYolu(row.ResimYolu);
                    }
                    @if (!string.IsNullOrEmpty(thumb))
                    {
                        <img src="@thumb" alt="@row.UrunAd" class="stok-hareket-urun-thumb" />
                    }
                    else
                    {
                        <div class="stok-hareket-urun-thumb--empty" title="Ürün resmi yok">
                            <i class="fa-solid fa-image"></i>
                        </div>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ItemStokHareketleri" Property="UrunKodu" Title="Ürün Kodu" Width="130px" />
            <RadzenDataGridColumn TItem="ItemStokHareketleri" Property="UrunAd" Title="Ürün Adı" MinWidth="180px" />
            <RadzenDataGridColumn TItem="ItemStokHareketleri"
                                  Property="HareketTipi"
                                  Title="Hareket Tipi"
                                  Width="130px"
                                  TextAlign="TextAlign.Center"
                                  FilterOperator="FilterOperator.Equals"
                                  FilterValue="@hareketTipiKolonFiltre">
                <Template Context="row">
                    @if (row.HareketTipi == 1) { <RadzenBadge Text="Giriş" BadgeStyle="BadgeStyle.Success" /> }
                    else if (row.HareketTipi == 2) { <RadzenBadge Text="Çıkış" BadgeStyle="BadgeStyle.Danger" /> }
                    else { <RadzenBadge Text="Diğer" BadgeStyle="BadgeStyle.Info" /> }
                </Template>
                <FilterTemplate>
                    <RadzenDropDown @bind-Value="@hareketTipiKolonFiltre"
                                    Data="@hareketTipiSecenekleri"
                                    TextProperty="Etiket"
                                    ValueProperty="Deger"
                                    TValue="short?"
                                    AllowClear="true"
                                    Placeholder="Tümü"
                                    Style="width:100%;" />
                </FilterTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ItemStokHareketleri" Property="Miktar" Title="Miktar" Width="110px" TextAlign="TextAlign.Right">
                <Template Context="row">
                    <span style="font-weight:600; color:@(row.HareketTipi == 1 ? "#2e7d32" : "#c62828")">
                        @(row.HareketTipi == 2 ? "-" : "+")@row.Miktar.ToString("N2")
                    </span>
                </Template>
                <FilterTemplate>
                    <GridTextFilter @bind-Value="@miktarFiltre" />
                </FilterTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ItemStokHareketleri" Property="Not" Title="Not" MinWidth="200px">
                <Template Context="row">@(string.IsNullOrWhiteSpace(row.Not) ? "-" : row.Not)</Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ItemStokHareketleri"
                                  Property="CreDate"
                                  FilterProperty="CreDate.Date"
                                  Title="Tarih"
                                  Width="160px"
                                  FormatString="{0:dd.MM.yyyy HH:mm}"
                                  FilterOperator="FilterOperator.Equals"
                                  FilterValue="@tarihKolonFiltre">
                <FilterTemplate>
                    <RadzenDatePicker @bind-Value="@tarihKolonFiltre"
                                      DateFormat="dd.MM.yyyy"
                                      ShowTime="false"
                                      AllowClear="true"
                                      Style="width:100%;" />
                </FilterTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ItemStokHareketleri" Title="İşlemler" Width="140px" TextAlign="TextAlign.Center"
                                  Sortable="false" Filterable="false" Frozen="true" FrozenPosition="FrozenColumnPosition.Right">
                <Template Context="row">
                    <RadzenButton Icon="visibility" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Variant="Variant.Flat"
                                  Click="@(() => OnInceleClick(row))" title="İncele" style="margin-right:4px;" />
                    <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Info" Size="ButtonSize.Small" Variant="Variant.Flat"
                                  Click="@(() => OnDuzenleClick(row))" Disabled="@urunSadecOkuma"
                                  Style="@(urunSadecOkuma ? "opacity:0.35;pointer-events:none;" : "")" title="Düzenle" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@code {
    [SupplyParameterFromQuery(Name = "tip")]
    public string? QueryTip { get; set; }

    [SupplyParameterFromQuery(Name = "bas")]
    public string? QueryBas { get; set; }

    [SupplyParameterFromQuery(Name = "bit")]
    public string? QueryBit { get; set; }

    private ItemStokHareketleri[] tumHareketler = [];
    private ItemStokHareketleri[] tarihFiltreliHareketler = [];
    private bool isLoading = true;
    private bool urunSadecOkuma;

    private short? filtreHareketTipi = null;
    private DateTime? filtreBasTarih = null;
    private DateTime? filtreBitTarih = null;
    private DateTime? tarihKolonFiltre;
    private short? hareketTipiKolonFiltre;
    private string? idFiltre;
    private string? miktarFiltre;

    private ItemStokHareketleri[] filtreliHareketler => tarihFiltreliHareketler
        .Where(x => !filtreHareketTipi.HasValue || x.HareketTipi == filtreHareketTipi.Value)
        .ToArray();

    private ItemStokHareketleri[] gridHareketler => filtreliHareketler.Where(h =>
        GridFilterHelper.Eslesir(h.ID, idFiltre) &&
        GridFilterHelper.Eslesir(h.Miktar, miktarFiltre)).ToArray();

    private readonly List<HareketTipiSecenegi> hareketTipiSecenekleri =
    [
        new(1, "Giriş"),
        new(2, "Çıkış"),
    ];

    private sealed record HareketTipiSecenegi(short Deger, string Etiket);

    private IList<ExportColumn<ItemStokHareketleri>> CiktiKolonlari() => new List<ExportColumn<ItemStokHareketleri>>
    {
        new() { Header = "ID",          Value = h => h.ID,        Align = ExportAlign.Right, Width = 0.6f },
        new() { Header = "Ürün Kodu",   Value = h => h.UrunKodu,  Width = 1.2f },
        new() { Header = "Ürün Adı",    Value = h => h.UrunAd,    Width = 2f   },
        new() { Header = "Hareket Tipi", Value = h => h.HareketTipi == 1 ? "Giriş" : (h.HareketTipi == 2 ? "Çıkış" : "Diğer"),
                                         Align = ExportAlign.Center, Width = 1f },
        new() { Header = "Miktar",      Value = h => h.Miktar,    Format = "N2", Align = ExportAlign.Right, Width = 0.9f },
        new() { Header = "Not",         Value = h => string.IsNullOrWhiteSpace(h.Not) ? "-" : h.Not, Width = 2f },
        new() { Header = "Tarih",       Value = h => h.CreDate,   Format = "dd.MM.yyyy HH:mm", Align = ExportAlign.Center, Width = 1.3f },
    };

    protected override async Task OnInitializedAsync()
    {
        await AuthState.InitializeAsync();
        await YetkiSvc.EnsureReadyAsync();
        if (!YetkiSvc.ErişimVar("/stok-hareketleri"))
        {
            Nav.NavigateTo("/erisim-engeli", true);
            return;
        }
        urunSadecOkuma = YetkiSvc.SadecOkuma("/urunler");
        await LoadAsync();
    }

    private static string? IlkResimYolu(string? resimYolu)
    {
        if (string.IsNullOrWhiteSpace(resimYolu))
            return null;

        return resimYolu
            .Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .FirstOrDefault();
    }

    private void OnInceleClick(ItemStokHareketleri row)
    {
        var barkod = row.BarkodNo?.Trim();
        if (string.IsNullOrEmpty(barkod))
        {
            NotificationSvc.Notify(NotificationSeverity.Warning, "İncele",
                "Bu ürün için barkod numarası tanımlı değil.", 4000);
            return;
        }

        Nav.NavigateTo($"/urun/{Uri.EscapeDataString(barkod)}");
    }

    private async Task OnDuzenleClick(ItemStokHareketleri row)
    {
        if (urunSadecOkuma || row.Urun_ID <= 0)
            return;

        var urunler = await DataSvc.GetUrun(row.Urun_ID);
        var item = urunler.FirstOrDefault();
        if (item is null)
        {
            NotificationSvc.Notify(NotificationSeverity.Warning, "Düzenle", "Ürün bulunamadı.", 4000);
            return;
        }

        var result = await DialogSvc.OpenAsync<UrunTnm>("Ürün Düzenle",
            new Dictionary<string, object?> { { "Item", item } },
            new DialogOptions { Width = "620px", Resizable = false, Draggable = true, CloseDialogOnOverlayClick = false });

        if (result is true)
            await LoadAsync();
    }

    protected override void OnParametersSet()
    {
        if (tumHareketler.Length == 0) return;
        ApplyQueryFilters();
        ApplyDateFilter();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        try
        {
            tumHareketler = await DataSvc.GetStokHareketleri();
            ApplyQueryFilters();
            ApplyDateFilter();
        }
        catch (Exception ex)
        {
            NotificationSvc.Notify(NotificationSeverity.Error, "Hata",
                "Veriler yüklenirken bir sorun oluştu: " + ex.Message, 5000);
        }
        finally { isLoading = false; }
    }

    private void ApplyQueryFilters()
    {
        if (!string.IsNullOrWhiteSpace(QueryTip))
            filtreHareketTipi = short.TryParse(QueryTip, out var tip) && tip is 1 or 2 ? tip : null;

        if (!string.IsNullOrWhiteSpace(QueryBas) && DateTime.TryParse(QueryBas, out var bas))
            filtreBasTarih = bas.Date;

        if (!string.IsNullOrWhiteSpace(QueryBit) && DateTime.TryParse(QueryBit, out var bit))
            filtreBitTarih = bit.Date;
    }

    private void ApplyDateFilter()
    {
        var sorgu = tumHareketler.AsEnumerable();
        if (filtreBasTarih.HasValue)
            sorgu = sorgu.Where(x => x.CreDate.Date >= filtreBasTarih.Value.Date);
        if (filtreBitTarih.HasValue)
            sorgu = sorgu.Where(x => x.CreDate.Date <= filtreBitTarih.Value.Date);
        tarihFiltreliHareketler = sorgu.ToArray();
    }

    private async Task ApplyDateFilterAsync()
    {
        ApplyDateFilter();
        await InvokeAsync(StateHasChanged);
    }

    private void ClearFilter()
    {
        filtreHareketTipi = null;
        filtreBasTarih = null;
        filtreBitTarih = null;
        tarihFiltreliHareketler = tumHareketler.ToArray();
        Nav.NavigateTo("/stok-hareketleri", forceLoad: false);
    }
}