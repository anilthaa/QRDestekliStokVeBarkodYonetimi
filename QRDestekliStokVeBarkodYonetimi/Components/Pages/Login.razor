@page "/login"
@layout QRDestekliStokVeBarkodYonetimi.Components.Layout.AuthLayout
@rendermode InteractiveServer
@using System.Net.Mail

<PageTitle>Giriş Yap</PageTitle>

@* Cookie yalnızca tam HTTP POST ile set edilir (Blazor circuit içinde SignInAsync çalışmaz). *@
<form id="auth-login-form" method="post" action="/api/auth/login" style="display:none;" aria-hidden="true">
    <input type="hidden" name="Eposta" value="" />
    <input type="hidden" name="Sifre" value="" />
    @if (!string.IsNullOrEmpty(ReturnUrl))
    {
        <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />
    }
</form>

<div class="auth-card">
    <div class="auth-card__brand">
        <i class="fa-solid fa-qrcode" style="font-size:2.4rem;color:#1b6ec2;"></i>
        <h1>QR Destekli Stok Yönetimi</h1>
        <p>Hesabınıza giriş yapın</p>
    </div>

    <div class="auth-form">
        @if (!string.IsNullOrEmpty(Registered))
        {
            <div class="rz-alert rz-alert-success" style="margin-bottom:0.75rem;">
                Kayıt başarılı. Şimdi giriş yapabilirsiniz.
            </div>
        }

        @if (!string.IsNullOrEmpty(Sifirlandi))
        {
            <div class="rz-alert rz-alert-success" style="margin-bottom:0.75rem;">
                Şifreniz güncellendi. Yeni şifrenizle giriş yapabilirsiniz.
            </div>
        }

        <div class="auth-field">
            <RadzenLabel Text="E-posta" Component="Eposta" />
            <RadzenTextBox @bind-Value="model.Eposta" Name="Eposta"
                           Placeholder="ornek@mail.com"
                           Style="width:100%;" Disabled="@girisIsBusy" />
        </div>

        <div class="auth-field">
            <div class="auth-label-row">
                <RadzenLabel Text="Şifre" Component="Sifre" Style="margin:0;" />
                <a class="auth-forgot-link" href="/sifremi-unuttum">Şifremi unuttum</a>
            </div>
            <TogglePasswordField @bind-Value="model.Sifre" Name="Sifre"
                                 Placeholder="••••••••" Disabled="@girisIsBusy" />
        </div>

        <div class="auth-remember-row" style="display:flex; align-items:center; gap:0.5rem;">
            <RadzenCheckBox @bind-Value="model.BeniHatirla" Name="BeniHatirla" Disabled="@girisIsBusy" />
            <RadzenLabel Text="Beni hatırla" Component="BeniHatirla" Style="margin:0; cursor:pointer;" />
        </div>

        @if (!string.IsNullOrEmpty(girisHata))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" AllowClose="false"
                        Style="margin-bottom:0.75rem;">@girisHata</RadzenAlert>
        }

        <RadzenButton Text="Giriş Yap" Icon="login" ButtonStyle="ButtonStyle.Primary"
                      Click="@GirisYapAsync" IsBusy="@girisIsBusy" BusyText="Giriş yapılıyor…"
                      Disabled="@girisIsBusy" Style="width:100%; margin-top:0.25rem;" />
    </div>

    <div class="auth-card__footer">
        Hesabınız yok mu? <a href="/register">Kayıt olun</a>
    </div>
</div>

@code {
    private sealed class LoginModel
    {
        public string Eposta { get; set; } = string.Empty;
        public string Sifre { get; set; } = string.Empty;
        public bool BeniHatirla { get; set; }
    }

    [SupplyParameterFromQuery] public string? Error { get; set; }
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] public string? Registered { get; set; }
    [SupplyParameterFromQuery] public string? Sifirlandi { get; set; }

    [CascadingParameter] public HttpContext? HttpContext { get; set; }

    private LoginModel model = new();
    private string girisHata = string.Empty;
    private bool girisIsBusy;

    protected override void OnInitialized()
    {
        if (HttpContext?.User?.Identity?.IsAuthenticated == true)
        {
            var hedef = KullaniciCookieSignInService.GuvenliReturnUrl(ReturnUrl);
            NavigationManager.NavigateTo(hedef, forceLoad: true);
        }
    }

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(Error))
            girisHata = Error;
    }

    private async Task GirisYapAsync()
    {
        girisHata = string.Empty;

        if (string.IsNullOrWhiteSpace(model.Eposta) || string.IsNullOrWhiteSpace(model.Sifre))
        {
            girisHata = "E-posta ve şifre zorunludur.";
            return;
        }

        var eposta = model.Eposta.Trim();
        if (!MailAddress.TryCreate(eposta, out _))
        {
            girisHata = "Geçerli bir e-posta giriniz.";
            return;
        }

        girisIsBusy = true;
        var postSubmitted = false;
        try
        {
            var result = await DataSvc.LoginKullanici(eposta, model.Sifre);
            if (result.Data is null)
            {
                girisHata = string.IsNullOrEmpty(result.SonucAciklama)
                    ? "Giriş başarısız."
                    : result.SonucAciklama;
                return;
            }

            var hedef = KullaniciCookieSignInService.GuvenliReturnUrl(ReturnUrl);
            await JS.InvokeVoidAsync("AuthLogin.post", eposta, model.Sifre, model.BeniHatirla, hedef == "/" ? "" : hedef);
            postSubmitted = true;
        }
        catch (Exception ex)
        {
            girisHata = "Giriş sırasında beklenmeyen bir hata oluştu: " + ex.Message;
        }
        finally
        {
            if (!postSubmitted)
                girisIsBusy = false;
        }
    }
}
