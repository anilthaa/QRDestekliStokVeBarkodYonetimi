@page "/login"
@layout QRDestekliStokVeBarkodYonetimi.Components.Layout.AuthLayout

@* @rendermode bilerek YOK — form-post için sayfanın static SSR olması gerekiyor.
   Cookie auth: form /api/auth/login'e POST eder, endpoint SignInAsync çağırıp redirect'ler. *@

<PageTitle>Giriş Yap</PageTitle>

<div class="auth-card">
    <div class="auth-card__brand">
        <i class="fa-solid fa-qrcode" style="font-size:2.4rem;color:#1b6ec2;"></i>
        <h1>QR Destekli Stok Yönetimi</h1>
        <p>Hesabınıza giriş yapın</p>
    </div>

    <form method="post" action="/api/auth/login" class="auth-form">
        @if (ReturnUrl is not null)
        {
            <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />
        }

        @if (!string.IsNullOrEmpty(Registered))
        {
            <div class="rz-alert rz-alert-success" style="margin-bottom:0.75rem;">
                Kayıt başarılı. Şimdi giriş yapabilirsiniz.
            </div>
        }

        @if (!string.IsNullOrEmpty(Sifirlandi))
        {
            <div class="rz-alert rz-alert-success" style="margin-bottom:0.75rem;">
                Şifreniz güncellendi. Yeni şifrenizle giriş yapabilirsiniz.
            </div>
        }

        <div class="auth-field">
            <label class="rz-label" for="Eposta">E-posta</label>
            <input id="Eposta" name="Eposta" type="email" required
                   placeholder="ornek@mail.com"
                   class="rz-textbox"
                   style="width:100%;" />
        </div>

        <div class="auth-field">
            <div class="auth-label-row">
                <label class="rz-label" for="Sifre" style="margin:0;">Şifre</label>
                <a class="auth-forgot-link" href="/sifremi-unuttum">Şifremi unuttum</a>
            </div>
            <input id="Sifre" name="Sifre" type="password" required
                   placeholder="••••••••"
                   class="rz-textbox"
                   style="width:100%;" />
        </div>

        <div class="auth-remember-row">
            <label class="auth-checkbox">
                <input type="checkbox" name="BeniHatirla" value="true" />
                <span>Beni hatırla</span>
            </label>
        </div>

        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="rz-alert rz-alert-danger" style="margin-bottom:0.75rem;">@Error</div>
        }

        <button type="submit" class="rz-button rz-button-md rz-button-primary"
                style="width:100%; margin-top:0.25rem;">
            <span class="rz-button-icon-left">
                <i class="fa-solid fa-right-to-bracket"></i>
            </span>
            <span class="rz-button-text">Giriş Yap</span>
        </button>
    </form>

    <div class="auth-card__footer">
        Hesabınız yok mu? <a href="/register">Kayıt olun</a>
    </div>
</div>

@code {
    [SupplyParameterFromQuery] public string? Error { get; set; }
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery] public string? Registered { get; set; }
    [SupplyParameterFromQuery] public string? Sifirlandi { get; set; }

    [CascadingParameter] public HttpContext? HttpContext { get; set; }

    protected override void OnInitialized()
    {
        // Zaten cookie ile auth olmuş kullanıcıyı doğrudan ana sayfaya gönder.
        if (HttpContext?.User?.Identity?.IsAuthenticated == true)
        {
            HttpContext.Response.Redirect(string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : ReturnUrl);
        }
    }
}
