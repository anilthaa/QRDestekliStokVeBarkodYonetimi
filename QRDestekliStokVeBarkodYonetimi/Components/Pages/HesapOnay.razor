@page "/hesap-onay"
@layout QRDestekliStokVeBarkodYonetimi.Components.Layout.AuthLayout

@* @rendermode bilerek YOK — onay işlemi /api/auth/confirm-account endpoint'inde tek seferde yapılır. *@

<PageTitle>Hesap onayı</PageTitle>

<div class="auth-card">
    <AuthCardHeader Title="Hesap onayı"
                    Subtitle="@AltBaslik" />

    @if (Basarili)
    {
        <div class="auth-message auth-message--success">
            Hesabınız onaylandı. Geçici şifreniz e-posta adresinize gönderildi.
            Giriş yaptıktan sonra profil sayfasından şifrenizi değiştirmenizi öneririz.
        </div>
        <a href="/login" class="auth-btn-link rz-button rz-button-md rz-primary">
            <i class="fa-solid fa-power-off" aria-hidden="true"></i> Giriş yap
        </a>
    }
    else if (!string.IsNullOrEmpty(Error))
    {
        <div class="auth-message auth-message--danger">@Error</div>
        <div class="auth-card__footer">
            <a href="/login">Giriş sayfasına dön</a>
        </div>
    }
    else
    {
        <div class="auth-message auth-message--danger">
            Geçerli bir onay bağlantısı bulunamadı. Lütfen e-postanızdaki bağlantıyı kullanın
            veya yöneticinizden yeni onay maili isteyin.
        </div>
        <div class="auth-card__footer">
            <a href="/login">Giriş sayfasına dön</a>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "success")]
    public string? Success { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    private bool Basarili => string.Equals(Success, "1", StringComparison.Ordinal);

    private string AltBaslik => Basarili
        ? "Hesabınız başarıyla onaylandı"
        : !string.IsNullOrEmpty(Error)
            ? "Onay işlemi tamamlanamadı"
            : "Hesap onay sonucu";
}
