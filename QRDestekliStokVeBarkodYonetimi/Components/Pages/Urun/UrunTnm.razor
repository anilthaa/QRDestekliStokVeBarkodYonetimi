@inject DataService DataSvc
@inject AuthStateService AuthState
@inject DialogService DialogSvc
@inject NotificationService NotificationSvc
@inject QrService QrSvc

<RadzenTemplateForm TItem="ItemUrun" Data="@model" Submit="@OnSubmitAsync">

    <div class="rz-p-4" style="min-width:480px; display:flex; flex-direction:column; gap:1rem;">

        <div style="display:flex; gap:1rem;">
            <div style="flex:1;">
                <RadzenLabel Text="Ürün Kodu *" Component="UrunKodu" />
                <RadzenTextBox @bind-Value="model.UrunKodu" Name="UrunKodu" Placeholder="Ürün kodu giriniz"
                               Style="width:100%" Disabled="@isBusy" />
                <RadzenRequiredValidator Component="UrunKodu" Text="Ürün kodu zorunludur." Style="display:block" />
            </div>
            <div style="flex:1;">
                <RadzenLabel Text="Barkod No" Component="BarkodNo" />
                <div style="display:flex; gap:0.4rem; align-items:center;">
                    <RadzenTextBox @bind-Value="model.BarkodNo" Name="BarkodNo" Placeholder="Barkod numarası"
                                   Style="flex:1" Disabled="@isBusy" />
                    <RadzenButton Icon="casino" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small"
                                  Variant="Variant.Flat" title="Rastgele barkod oluştur"
                                  Click="@OnRandomBarkodClick" Disabled="@isBusy" />
                </div>
            </div>
        </div>

        <div>
            <RadzenLabel Text="Ürün Adı *" Component="Ad" />
            <RadzenTextBox @bind-Value="model.Ad" Name="Ad" Placeholder="Ürün adı giriniz"
                           Style="width:100%" Disabled="@isBusy" />
            <RadzenRequiredValidator Component="Ad" Text="Ürün adı zorunludur." Style="display:block" />
        </div>

        <div>
            <RadzenLabel Text="Açıklama" Component="Aciklama" />
            <RadzenTextArea @bind-Value="model.Aciklama" Name="Aciklama" Placeholder="Açıklama (opsiyonel)"
                            Style="width:100%" Rows="3" Disabled="@isBusy" />
        </div>

        <div style="display:flex; gap:1rem;">
            <div style="flex:1;">
                <RadzenLabel Text="Kategori *" Component="Kategori_ID" />
                <RadzenDropDown @bind-Value="model.Kategori_ID" Name="Kategori_ID"
                                Data="@kategoriler" TextProperty="Ad" ValueProperty="ID"
                                Placeholder="Kategori seçiniz" Style="width:100%"
                                Disabled="@isBusy" AllowClear="true" />
                <RadzenRequiredValidator Component="Kategori_ID" Text="Kategori zorunludur." Style="display:block" />
            </div>
            <div style="flex:1;">
                <RadzenLabel Text="Birim *" Component="Birim_ID" />
                <RadzenDropDown @bind-Value="model.Birim_ID" Name="Birim_ID"
                                Data="@birimler" TextProperty="Ad" ValueProperty="ID"
                                Placeholder="Birim seçiniz" Style="width:100%"
                                Disabled="@isBusy" AllowClear="true" />
                <RadzenRequiredValidator Component="Birim_ID" Text="Birim zorunludur." Style="display:block" />
            </div>
        </div>

        <div style="display:flex; gap:1rem;">
            <div style="flex:1;">
                <RadzenLabel Text="Stok Miktarı" Component="Stok" />
                <RadzenNumeric @bind-Value="model.Stok" Name="Stok"
                               Style="width:100%" Disabled="@isBusy" Min="0" />
            </div>
            <div style="flex:1;">
                <RadzenLabel Text="Kritik Stok Seviyesi" Component="KritikStokSeviyesi" />
                <RadzenNumeric @bind-Value="model.KritikStokSeviyesi" Name="KritikStokSeviyesi"
                               Style="width:100%" Disabled="@isBusy" Min="0" />
            </div>
        </div>

        <div>
            <RadzenLabel Text="Resim Yolu" Component="ResimYolu" />
            <RadzenTextBox @bind-Value="model.ResimYolu" Name="ResimYolu" Placeholder="/images/urun.png"
                           Style="width:100%" Disabled="@isBusy" />
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat"
                         AllowClose="false">@errorMessage</RadzenAlert>
        }

        <div style="display:flex; justify-content:flex-end; gap:0.5rem; margin-top:0.5rem;">
            <RadzenButton ButtonStyle="ButtonStyle.Light" Text="İptal" Icon="cancel"
                          Click="@OnCancel" Disabled="@isBusy" />
            <RadzenButton ButtonType="ButtonType.Submit" Text="Kaydet" Icon="save"
                          IsBusy="@isBusy" BusyText="Kaydediliyor..." />
        </div>

    </div>

</RadzenTemplateForm>

@code {
    [Parameter] public ItemUrun? Item { get; set; }

    private ItemUrun model = new() { Stok = 0, KritikStokSeviyesi = 0 };
    private bool isBusy;
    private string? errorMessage;

    private ItemKategori[] kategoriler = [];
    private ItemBirim[] birimler = [];

    protected override async Task OnInitializedAsync()
    {
        kategoriler = await DataSvc.GetKategori();
        birimler    = await DataSvc.GetBirim();
    }

    protected override void OnParametersSet()
    {
        if (Item is not null)
        {
            model = new ItemUrun
            {
                ID                  = Item.ID,
                UrunKodu            = Item.UrunKodu,
                Kategori_ID         = Item.Kategori_ID,
                BarkodNo            = Item.BarkodNo,
                ResimYolu           = Item.ResimYolu,
                Ad                  = Item.Ad,
                Aciklama            = Item.Aciklama,
                Birim_ID            = Item.Birim_ID,
                Stok                = Item.Stok,
                KritikStokSeviyesi  = Item.KritikStokSeviyesi,
                CreUser             = Item.CreUser,
                CreDate             = Item.CreDate,
                UpdUser             = Item.UpdUser,
                UpdDate             = Item.UpdDate,
                DelUser             = Item.DelUser,
                DelDate             = Item.DelDate
            };
        }
    }

    private void OnRandomBarkodClick()
    {
        model.BarkodNo = QrSvc.GenerateRandomBarkod();
    }

    private async Task OnSubmitAsync()
    {
        errorMessage = null;
        isBusy = true;
        try
        {
            int userId = AuthState.CurrentUser?.ID ?? 0;

            if (model.ID == 0)
                model.CreUser = userId;
            else
                model.UpdUser = userId;

            model.DelUser = 0;

            var result = await DataSvc.SetUrun(model);

            if (result.SonucKodu < 0)
            {
                errorMessage = result.SonucAciklama ?? "Bir hata oluştu.";
                return;
            }

            NotificationSvc.Notify(NotificationSeverity.Success, "Başarılı",
                model.ID == 0 ? "Ürün eklendi." : "Ürün güncellendi.", 3000);

            DialogSvc.Close(true);
        }
        catch (Exception ex)
        {
            errorMessage = $"Beklenmeyen hata: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private void OnCancel() => DialogSvc.Close(false);
}