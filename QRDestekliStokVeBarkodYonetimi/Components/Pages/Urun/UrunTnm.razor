@inject DataService DataSvc
@inject AuthStateService AuthState
@inject DialogService DialogSvc
@inject NotificationService NotificationSvc
@inject QrService QrSvc
@inject IWebHostEnvironment Env

<RadzenTemplateForm TItem="ItemUrun" Data="@model" Submit="@OnSubmitAsync">

    <div class="form-shell form-shell--wide rz-p-4">

        <div class="form-row">
            <div>
                <KarakterLimitliMetin Label="Ürün Kodu" Name="UrunKodu" @bind-Value="model.UrunKodu"
                                      MaxLength="@UrunAlanSinirlari.UrunKodu" Required="true"
                                      Placeholder="Ürün kodu giriniz" Disabled="@isBusy" />
            </div>
            <div>
                <RadzenLabel Text="Barkod No" Component="BarkodNo" />
                <div style="display:flex; gap:0.4rem; align-items:flex-start;">
                    <div style="flex:1; min-width:0;">
                        <KarakterLimitliMetin Name="BarkodNo" @bind-Value="model.BarkodNo" ShowLabel="false"
                                              MaxLength="@UrunAlanSinirlari.BarkodNo"
                                              Placeholder="Barkod numarası" Disabled="@isBusy" Style="width:100%" />
                    </div>
                    <RadzenButton Icon="casino" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small"
                                  Variant="Variant.Flat" title="Rastgele barkod oluştur"
                                  Click="@OnRandomBarkodClick" Disabled="@isBusy"
                                  Style="margin-top:0.15rem;" />
                </div>
            </div>
        </div>

        <div>
            <KarakterLimitliMetin Label="Ürün Adı" Name="Ad" @bind-Value="model.Ad"
                                  MaxLength="@UrunAlanSinirlari.Ad" Required="true"
                                  Placeholder="Ürün adı giriniz" Disabled="@isBusy" />
        </div>

        <div>
            <KarakterLimitliMetin Label="Açıklama" Name="Aciklama" @bind-Value="model.Aciklama"
                                  MaxLength="@UrunAlanSinirlari.Aciklama" Multiline="true" Rows="3"
                                  Placeholder="Açıklama (opsiyonel)" Disabled="@isBusy" />
        </div>

        <div class="form-row">
            <div>
                <RadzenLabel Text="Kategori *" Component="Kategori_ID" />
                <RadzenDropDown @bind-Value="model.Kategori_ID" Name="Kategori_ID"
                                Data="@kategoriler" TextProperty="Ad" ValueProperty="ID"
                                Placeholder="Kategori seçiniz" Style="width:100%"
                                Disabled="@isBusy" AllowClear="true" />
                <RadzenRequiredValidator Component="Kategori_ID" Text="Kategori zorunludur." Style="display:block" />
            </div>
            <div>
                <RadzenLabel Text="Birim *" Component="Birim_ID" />
                <RadzenDropDown @bind-Value="model.Birim_ID" Name="Birim_ID"
                                Data="@birimler" TextProperty="Ad" ValueProperty="ID"
                                Placeholder="Birim seçiniz" Style="width:100%"
                                Disabled="@isBusy" AllowClear="true" />
                <RadzenRequiredValidator Component="Birim_ID" Text="Birim zorunludur." Style="display:block" />
            </div>
        </div>

        <div class="form-row">
            <div>
                <RadzenLabel Text="Stok Miktarı" Component="Stok" />
                <RadzenNumeric @bind-Value="model.Stok" Name="Stok"
                               Style="width:100%" Disabled="@isBusy" Min="0" />
            </div>
            <div>
                <RadzenLabel Text="Kritik Stok Seviyesi" Component="KritikStokSeviyesi" />
                <RadzenNumeric @bind-Value="model.KritikStokSeviyesi" Name="KritikStokSeviyesi"
                               Style="width:100%" Disabled="@isBusy" Min="0" />
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(onizlemeResim))
        {
            <div @onclick="@(() => onizlemeResim = null)"
                 style="position:fixed; inset:0; background:rgba(0,0,0,0.82); z-index:9999;
                        display:flex; align-items:center; justify-content:center; cursor:zoom-out;">
                <img src="@onizlemeResim" alt="Tam görünüm"
                     style="max-width:90vw; max-height:90vh; border-radius:10px; box-shadow:0 4px 32px #000;" />
            </div>
        }

        <!-- Çoklu resim yükleme -->
        <div>
            <RadzenLabel Text="Ürün Resimleri" />

            @if (resimListesi.Count > 0)
            {
                <div style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-bottom:0.75rem;">
                    @foreach (var resim in resimListesi)
                    {
                        var resimKopyasi = resim;
                        <div style="position:relative; display:inline-block;">
                            <img src="@resimKopyasi" alt="Ürün resmi"
                                 style="width:90px; height:90px; object-fit:cover; border-radius:8px; border:1px solid #ddd; cursor:zoom-in;"
                                 @onclick="@(() => onizlemeResim = resimKopyasi)" />
                            <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                          Variant="Variant.Flat"
                                          Style="position:absolute; top:2px; right:2px; padding:1px 5px; min-width:unset;"
                                          Click="@(() => ResimSil(resimKopyasi))" title="Resmi kaldır" />
                        </div>
                    }
                </div>
            }

            <InputFile OnChange="@OnResimSecildi" accept="image/*" multiple
                       style="display:block; margin-top:4px;" disabled="@isBusy" />
            <div style="font-size:0.78rem; color:#888; margin-top:2px;">
                Birden fazla resim seçebilirsiniz. Maksimum 5 resim, her biri en fazla 5 MB.
            </div>

            @if (resimYukleniyor)
            {
                <div style="font-size:0.8rem; color:#555; margin-top:4px;">
                    <RadzenProgressBar Value="100" Mode="ProgressBarMode.Indeterminate" Style="height:6px;" />
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(resimHata))
            {
                <div style="font-size:0.8rem; color:#c62828; margin-top:4px;">@resimHata</div>
            }
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat"
                         AllowClose="false">@errorMessage</RadzenAlert>
        }

        <div class="form-actions">
            <RadzenButton ButtonStyle="ButtonStyle.Light" Text="İptal" Icon="cancel"
                          Click="@OnCancel" Disabled="@isBusy" />
            <RadzenButton ButtonType="ButtonType.Submit" Text="Kaydet" Icon="save"
                          IsBusy="@isBusy" BusyText="Kaydediliyor..."
                          Disabled="@(isBusy || metinSinirlariAsildi)" />
        </div>

    </div>

</RadzenTemplateForm>

@code {
    [Parameter] public ItemUrun? Item { get; set; }

    private ItemUrun model = new() { Stok = 0, KritikStokSeviyesi = 0 };
    private bool isBusy;
    private string? errorMessage;
    private bool resimYukleniyor;
    private string? resimHata;

    private string? onizlemeResim;

    private List<string> resimListesi = new();

    private ItemKategori[] kategoriler = [];
    private ItemBirim[] birimler = [];

    private bool metinSinirlariAsildi => UrunMetinDogrulama.SinirAsildi(model);

    private static readonly string[] IzinliUzantilar = [".jpg", ".jpeg", ".png", ".gif", ".webp"];
    private const long MaxResimBoyutu = 5 * 1024 * 1024; // 5 MB
    private const int MaxResimSayisi = 5;

    protected override async Task OnInitializedAsync()
    {
        kategoriler = await DataSvc.GetKategori();
        birimler    = await DataSvc.GetBirim();
    }

    protected override void OnParametersSet()
    {
        if (Item is not null)
        {
            model = new ItemUrun
            {
                ID                  = Item.ID,
                UrunKodu            = Item.UrunKodu,
                Kategori_ID         = Item.Kategori_ID,
                BarkodNo            = Item.BarkodNo,
                ResimYolu           = Item.ResimYolu,
                Ad                  = Item.Ad,
                Aciklama            = Item.Aciklama,
                Birim_ID            = Item.Birim_ID,
                Stok                = Item.Stok,
                KritikStokSeviyesi  = Item.KritikStokSeviyesi,
                CreUser             = Item.CreUser,
                CreDate             = Item.CreDate,
                UpdUser             = Item.UpdUser,
                UpdDate             = Item.UpdDate,
                DelUser             = Item.DelUser,
                DelDate             = Item.DelDate
            };

            // Mevcut resimleri listeye yükle
            if (!string.IsNullOrWhiteSpace(Item.ResimYolu))
            {
                resimListesi = Item.ResimYolu
                    .Split(';', StringSplitOptions.RemoveEmptyEntries)
                    .Select(s => s.Trim())
                    .ToList();
            }
        }
    }

    private async Task OnResimSecildi(InputFileChangeEventArgs e)
    {
        resimHata = null;

        var kalanSlot = MaxResimSayisi - resimListesi.Count;
        if (kalanSlot <= 0)
        {
            resimHata = $"En fazla {MaxResimSayisi} resim eklenebilir.";
            return;
        }

        var dosyalar = e.GetMultipleFiles(kalanSlot);
        resimYukleniyor = true;

        try
        {
            var klasor = Path.Combine(Env.WebRootPath, "uploads", "urunler");
            Directory.CreateDirectory(klasor);

            foreach (var dosya in dosyalar)
            {
                var uzanti = Path.GetExtension(dosya.Name).ToLowerInvariant();
                if (!IzinliUzantilar.Contains(uzanti))
                {
                    resimHata = $"{dosya.Name}: Desteklenmeyen dosya türü.";
                    continue;
                }
                if (dosya.Size > MaxResimBoyutu)
                {
                    resimHata = $"{dosya.Name}: Dosya 5 MB sınırını aşıyor.";
                    continue;
                }

                var dosyaAdi = $"{Guid.NewGuid()}{uzanti}";
                var hedef = Path.Combine(klasor, dosyaAdi);

                await using var stream = dosya.OpenReadStream(MaxResimBoyutu);
                await using var fs = File.Create(hedef);
                await stream.CopyToAsync(fs);

                resimListesi.Add($"/uploads/urunler/{dosyaAdi}");
            }
        }
        catch (Exception ex)
        {
            resimHata = "Yükleme hatası: " + ex.Message;
        }
        finally
        {
            resimYukleniyor = false;
        }
    }

    private void ResimSil(string yol)
    {
        var fizikselYol = Path.Combine(Env.WebRootPath, yol.TrimStart('/').Replace('/', Path.DirectorySeparatorChar));
        if (File.Exists(fizikselYol)) File.Delete(fizikselYol);
        resimListesi.Remove(yol);
    }

    private void OnRandomBarkodClick()
    {
        model.BarkodNo = QrSvc.GenerateRandomBarkod();
    }

    private async Task OnSubmitAsync()
    {
        errorMessage = null;

        if (metinSinirlariAsildi)
        {
            errorMessage = UrunMetinDogrulama.IlkHata(model);
            return;
        }

        isBusy = true;
        try
        {
            int userId = AuthState.CurrentUser?.ID ?? 0;

            if (model.ID == 0)
                model.CreUser = userId;
            else
                model.UpdUser = userId;

            model.DelUser = 0;

            model.ResimYolu = resimListesi.Count > 0 ? string.Join(";", resimListesi) : null;

            var yeniKayit = model.ID == 0;
            var result = await DataSvc.SetUrun(model);

            if (result.SonucKodu < 0)
            {
                errorMessage = result.SonucAciklama ?? "Bir hata oluştu.";
                return;
            }

            NotificationSvc.Notify(NotificationSeverity.Success, "Başarılı",
                yeniKayit ? "Ürün eklendi." : "Ürün güncellendi.", 3000);

            DialogSvc.Close(true);
        }
        catch (Exception ex)
        {
            errorMessage = $"Beklenmeyen hata: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private void OnCancel() => DialogSvc.Close(false);
}