<div class="rz-p-4" style="display:flex; flex-direction:column; align-items:center; gap:1rem; min-width:320px;">

    @if (!string.IsNullOrEmpty(qrBase64))
    {
        <div style="text-align:center;">
            <p style="margin:0 0 0.25rem 0; color:#555; font-size:0.85rem;">Barkod: <strong>@BarkodNo</strong></p>
            <p style="margin:0 0 0.5rem 0; color:#555; font-size:0.85rem;">Ürün: <strong>@UrunAdi</strong></p>
            @if (!string.IsNullOrEmpty(detayUrl))
            {
                <p style="margin:0 0 1rem 0; color:#666; font-size:0.78rem; word-break:break-all; max-width:300px;">
                    QR içeriği: <span style="color:#4338ca;">@detayUrl</span>
                </p>
            }
        </div>

        <img src="data:image/png;base64,@qrBase64"
             alt="QR Kod"
             style="width:260px; height:260px; border:1px solid #e0e0e0; border-radius:8px; padding:8px; background:#fff;" />

        <a href="data:image/png;base64,@qrBase64"
           download="@($"qr_{BarkodNo}.png")"
           style="text-decoration:none;">
            <RadzenButton Text="PNG İndir" Icon="download" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small" />
        </a>
    }
    else
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" Variant="Variant.Flat" AllowClose="false">
            Bu ürün için barkod tanımlanmamış. QR kod oluşturulamadı.
        </RadzenAlert>
    }

    <RadzenButton Text="Kapat" Icon="close" ButtonStyle="ButtonStyle.Light"
                  Click="@(() => DialogSvc.Close())" Style="margin-top:0.5rem;" />

</div>

@code {
    [Parameter] public string? BarkodNo { get; set; }
    [Parameter] public string? UrunAdi { get; set; }

    [Inject] private NavigationManager Nav { get; set; } = default!;

    private string? qrBase64;
    private string? detayUrl;

    protected override void OnParametersSet()
    {
        detayUrl = QrSvc.BuildUrunDetayUrl(Nav.BaseUri, BarkodNo);
        qrBase64 = QrSvc.GenerateQrBase64(detayUrl);
    }
}