@page "/urunler"
@layout QRDestekliStokVeBarkodYonetimi.Components.Layout.MainLayout
@rendermode InteractiveServer

@implements IDisposable

@inject YetkiService YetkiSvc
@inject NavigationManager Nav

<PageTitle>Ürünler</PageTitle>

<div class="page-header">
    <h3 class="page-header-title">Ürün Listesi</h3>
    <div class="page-header-actions">
        <ExportButton TItem="ItemUrun"
                      Items="@urunler"
                      Title="Ürün Listesi"
                      FileName="urun-listesi"
                      Columns="@CiktiKolonlari()" />
        <RadzenButton Text="Yeni Ürün" Icon="add" ButtonStyle="ButtonStyle.Primary"
                      Click="@OnYeniClick"
                      Disabled="@sadecOkuma"
                      Style="@(sadecOkuma ? "opacity:0.35;pointer-events:none;" : "")" />
    </div>
</div>

@if (isLoading)
{
    <div style="display:flex; justify-content:center; padding:2rem;">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                   Size="ProgressBarCircularSize.Large" />
    </div>
}
else
{
    <RadzenDataGrid @ref="gridRef" Data="@filtreliUrunler" TItem="ItemUrun" AllowSorting="true"
                    AllowFiltering="true" FilterMode="FilterMode.Simple"
                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                    AllowPaging="true" PageSize="15"
                    EmptyText="Kayıt bulunamadı."
                    ColumnWidth="200px">
        <Columns>
            <RadzenDataGridColumn TItem="ItemUrun" Property="ID" Title="Sıra" Width="@GridSiraYardimci.KolonGenisligi" MinWidth="@GridSiraYardimci.KolonGenisligi"
                                  Frozen="true" Filterable="false"
                                  SortComparer="@GridSiraYardimci.SiralamaIndeksiComparer(filtreliUrunler)"
                                  TextAlign="TextAlign.Center" CssClass="grid-sira-kolon">
                <Template Context="row">
                    @GridSiraYardimci.ListeSirasi(filtreliUrunler, row)
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ItemUrun" Title="Resim" Width="72px" TextAlign="TextAlign.Center"
                                  Sortable="false" Filterable="false">
                <Template Context="row">
                    @{
                        var thumb = UrunResimYardimci.IlkResimYolu(row.ResimYolu);
                    }
                    @if (!string.IsNullOrEmpty(thumb))
                    {
                        <img src="@thumb" alt="@row.Ad" class="urun-list-thumb" />
                    }
                    else
                    {
                        <div class="urun-list-thumb--empty" title="Ürün resmi yok">
                            <i class="fa-solid fa-image"></i>
                        </div>
                    }
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ItemUrun" Property="UrunKodu" Title="Ürün Kodu" MinWidth="120px" />
            <RadzenDataGridColumn TItem="ItemUrun" Property="Ad" Title="Ürün Adı" MinWidth="180px" />
            <RadzenDataGridColumn TItem="ItemUrun" Property="BarkodNo" Title="Barkod No" MinWidth="140px" />
            <RadzenDataGridColumn TItem="ItemUrun" Property="Kategori_ID" Title="Kategori" MinWidth="140px">
                <Template Context="row">
                    @(kategoriler.FirstOrDefault(k => k.ID == row.Kategori_ID)?.Ad ?? "-")
                </Template>
                <FilterTemplate>
                    <GridLookupFilter @bind-Value="@kategoriFiltreId" Data="@kategoriler" />
                </FilterTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ItemUrun" Property="Birim_ID" Title="Birim" Width="100px">
                <Template Context="row">
                    @(birimler.FirstOrDefault(b => b.ID == row.Birim_ID)?.Ad ?? "-")
                </Template>
                <FilterTemplate>
                    <GridLookupFilter @bind-Value="@birimFiltreId" Data="@birimler" />
                </FilterTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ItemUrun" Property="Stok" Title="Stok" Width="90px" TextAlign="TextAlign.Right">
                <Template Context="row">
                    <span style="@(row.Stok <= row.KritikStokSeviyesi ? "color:#c62828; font-weight:600;" : "")">@row.Stok</span>
                </Template>
                <FilterTemplate>
                    <GridTextFilter @bind-Value="@stokFiltre" />
                </FilterTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ItemUrun" Property="KritikStokSeviyesi" Title="Kritik Stok" Width="120px" TextAlign="TextAlign.Right">
                <FilterTemplate>
                    <GridTextFilter @bind-Value="@kritikStokFiltre" />
                </FilterTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ItemUrun" Property="Aciklama" Title="Açıklama" MinWidth="200px" />
            <RadzenDataGridColumn TItem="ItemUrun" Title="" Width="48px" TextAlign="TextAlign.Center"
                                  Sortable="false" Filterable="false">
                <Template Context="row">
                    <GridIslemMenuButonu Click="@(e => IslemlerMenuAc(e, row))" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@code {
    private RadzenDataGrid<ItemUrun>? gridRef;
    private ItemUrun[] urunler = [];
    private ItemKategori[] kategoriler = [];
    private ItemBirim[] birimler = [];
    private bool isLoading = true;
    private bool sadecOkuma = false;
    private int? kategoriFiltreId;
    private int? birimFiltreId;
    private string? stokFiltre;
    private string? kritikStokFiltre;
    private ItemUrun? menuSatir;

    private ItemUrun[] filtreliUrunler => urunler.Where(u =>
        GridFilterHelper.IdEslesir(u.Kategori_ID, kategoriFiltreId) &&
        GridFilterHelper.IdEslesir(u.Birim_ID, birimFiltreId) &&
        GridFilterHelper.Eslesir(u.Stok, stokFiltre) &&
        GridFilterHelper.Eslesir(u.KritikStokSeviyesi, kritikStokFiltre)).ToArray();

    private IList<ExportColumn<ItemUrun>> CiktiKolonlari()
    {
        var liste = urunler.ToList();
        return new List<ExportColumn<ItemUrun>>
    {
        new() { Header = "Sıra",        Value = u => GridSiraYardimci.ExportSirasi(liste, u), Align = ExportAlign.Right, Width = 0.6f },
        new() { Header = "Ürün Kodu",   Value = u => u.UrunKodu,    Width = 1.2f },
        new() { Header = "Ürün Adı",    Value = u => u.Ad,          Width = 2f   },
        new() { Header = "Barkod No",   Value = u => u.BarkodNo,    Width = 1.4f },
        new() { Header = "Kategori",    Value = u => kategoriler.FirstOrDefault(k => k.ID == u.Kategori_ID)?.Ad ?? "-", Width = 1.4f },
        new() { Header = "Birim",       Value = u => birimler.FirstOrDefault(b => b.ID == u.Birim_ID)?.Ad ?? "-", Width = 0.9f },
        new() { Header = "Stok",        Value = u => u.Stok,        Format = "N0", Align = ExportAlign.Right, Width = 0.8f },
        new() { Header = "Kritik Stok", Value = u => u.KritikStokSeviyesi, Format = "N0", Align = ExportAlign.Right, Width = 0.9f },
        new() { Header = "Açıklama",    Value = u => u.Aciklama,    Width = 2f   },
    };
    }

    protected override async Task OnInitializedAsync()
    {
        await AuthState.InitializeAsync();
        await YetkiSvc.EnsureReadyAsync();
        if (!YetkiSvc.ErişimVar("/urunler"))
        {
            Nav.NavigateTo("/erisim-engeli", true);
            return;
        }
        sadecOkuma = YetkiSvc.SadecOkuma("/urunler");
        Nav.LocationChanged += OnLocationChanged;
        await LoadAsync();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var path = new Uri(e.Location).AbsolutePath.TrimEnd('/');
        if (string.Equals(path, "/urunler", StringComparison.OrdinalIgnoreCase))
            _ = InvokeAsync(() => LoadAsync(tamSpinner: false));
    }

    public void Dispose()
        => Nav.LocationChanged -= OnLocationChanged;

    private async Task LoadAsync(bool tamSpinner = true)
    {
        if (tamSpinner) isLoading = true;
        try
        {
            urunler     = await DataSvc.GetUrun();
            kategoriler = await DataSvc.GetKategori();
            birimler    = await DataSvc.GetBirim();
        }
        finally { if (tamSpinner) isLoading = false; }

        await InvokeAsync(StateHasChanged);
        if (gridRef is not null)
            await gridRef.Reload();
    }

    private async Task OnYeniClick()
    {
        if (sadecOkuma) return;
        var result = await DialogSvc.OpenAsync<UrunTnm>("Yeni Ürün",
            new Dictionary<string, object?> { { "Item", new ItemUrun { Stok = 0, KritikStokSeviyesi = 0 } } },
            new DialogOptions { Width = "620px", Resizable = false, Draggable = true, CloseDialogOnOverlayClick = false });
        if (result is bool kaydedildi && kaydedildi)
            await LoadAsync(tamSpinner: false);
    }

    private void IslemlerMenuAc(MouseEventArgs args, ItemUrun row)
    {
        menuSatir = row;
        ContextMenuSvc.Open(args,
            new List<ContextMenuItem>
            {
                new() { Text = "QR Kodu Göster", Icon = "qr_code", Value = "qr" },
                new() { Text = "Barkodu Göster", Icon = "barcode_reader", Value = "barkod" },
                new() { Text = "İncele", Icon = "visibility", Value = "incele" },
                new() { Text = "Düzenle", Icon = "edit", Value = "duzenle", Disabled = sadecOkuma },
                new() { Text = "Sil", Icon = "delete", Value = "sil", Disabled = sadecOkuma }
            },
            OnIslemMenuSecildi);
    }

    private void OnIslemMenuSecildi(MenuItemEventArgs args)
    {
        _ = InvokeAsync(async () =>
        {
            if (menuSatir is null)
                return;

            var row = menuSatir;
            menuSatir = null;

            switch (args.Value?.ToString())
            {
                case "qr":
                    await OnQrClick(row);
                    break;
                case "barkod":
                    await OnBarkodClick(row);
                    break;
                case "incele":
                    await OnInceleClick(row);
                    break;
                case "duzenle":
                    await OnDuzenleClick(row);
                    break;
                case "sil":
                    await OnSilClick(row);
                    break;
            }
        });
    }

    private async Task OnInceleClick(ItemUrun item)
    {
        await DialogSvc.OpenAsync<UrunTnm>("Ürün İncele",
            new Dictionary<string, object?> { { "Item", item }, { "SadeceIncele", true } },
            new DialogOptions { Width = "620px", Resizable = false, Draggable = true, CloseDialogOnOverlayClick = false });
    }

    private async Task OnDuzenleClick(ItemUrun item)
    {
        if (sadecOkuma) return;
        var result = await DialogSvc.OpenAsync<UrunTnm>("Ürün Düzenle",
            new Dictionary<string, object?> { { "Item", item } },
            new DialogOptions { Width = "620px", Resizable = false, Draggable = true, CloseDialogOnOverlayClick = false });
        if (result is bool kaydedildi && kaydedildi)
            await LoadAsync(tamSpinner: false);
    }

    private async Task OnQrClick(ItemUrun item)
    {
        await DialogSvc.OpenAsync<UrunQr>($"{item.Ad} — QR Kod",
            new Dictionary<string, object?> { { "BarkodNo", item.BarkodNo }, { "UrunAdi", item.Ad } },
            new DialogOptions { Width = "380px", Resizable = false, Draggable = true, CloseDialogOnOverlayClick = true });
    }

    private async Task OnBarkodClick(ItemUrun item)
    {
        await DialogSvc.OpenAsync<UrunBarkod>($"{item.Ad} — Barkod",
            new Dictionary<string, object?> { { "BarkodNo", item.BarkodNo }, { "UrunAdi", item.Ad } },
            new DialogOptions { Width = "480px", Resizable = false, Draggable = true, CloseDialogOnOverlayClick = true });
    }

    private async Task OnSilClick(ItemUrun item)
    {
        if (sadecOkuma) return;
        var onay = await DialogSvc.Confirm(
            DialogFragments.Html($"{DialogFragments.B(item.Ad)} ürününü silmek istediğinizden emin misiniz?"), "Ürün Sil",
            new ConfirmOptions { OkButtonText = "Evet, Sil", CancelButtonText = "İptal" });
        if (onay != true) return;

        int userId = AuthState.CurrentUser?.ID ?? 0;
        var silItem = new ItemUrun
        {
            ID = item.ID, UrunKodu = item.UrunKodu, Ad = item.Ad,
            Kategori_ID = item.Kategori_ID, Birim_ID = item.Birim_ID,
            Stok = item.Stok, KritikStokSeviyesi = item.KritikStokSeviyesi,
            CreUser = item.CreUser, DelUser = userId
        };
        var result = await DataSvc.SetUrun(silItem);
        if (result.SonucKodu < 0)
            NotificationSvc.Notify(NotificationSeverity.Error, "Hata", result.SonucAciklama ?? "Silme işlemi başarısız.", 4000);
        else
        {
            NotificationSvc.Notify(NotificationSeverity.Success, "Başarılı", $"{item.Ad} silindi.", 3000);
            await LoadAsync(tamSpinner: false);
        }
    }
}