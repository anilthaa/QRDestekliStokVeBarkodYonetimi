@page "/kategoriler"
@layout QRDestekliStokVeBarkodYonetimi.Components.Layout.MainLayout
@rendermode InteractiveServer

@inject YetkiService YetkiSvc
@inject NavigationManager Nav

<PageTitle>Kategoriler</PageTitle>

<div class="page-header">
    <h3 class="page-header-title">Kategori Listesi</h3>
    <div class="page-header-actions">
        <ExportButton TItem="ItemKategori"
                      Items="@kategoriler"
                      Title="Kategori Listesi"
                      FileName="kategori-listesi"
                      Columns="@CiktiKolonlari()" />
        <RadzenButton Text="Yeni Kategori" Icon="add" ButtonStyle="ButtonStyle.Primary"
                      Click="@OnYeniClick"
                      Disabled="@sadecOkuma"
                      Style="@(sadecOkuma ? "opacity:0.35;pointer-events:none;" : "")" />
    </div>
</div>

@if (isLoading)
{
    <div style="display:flex; justify-content:center; padding:2rem;">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                   Size="ProgressBarCircularSize.Large" />
    </div>
}
else
{
    <RadzenDataGrid Data="@kategoriler" TItem="ItemKategori" AllowSorting="true"
                    AllowFiltering="true" FilterMode="FilterMode.Simple"
                    AllowPaging="true" PageSize="15"
                    EmptyText="Kayıt bulunamadı."
                    ColumnWidth="200px">
        <Columns>

            <RadzenDataGridColumn TItem="ItemKategori" Property="ID" Title="ID"
                                  Width="70px" Frozen="true" />

            <RadzenDataGridColumn TItem="ItemKategori" Property="Ad" Title="Kategori Adı"
                                  MinWidth="160px" />

            <RadzenDataGridColumn TItem="ItemKategori" Property="Aciklama" Title="Açıklama"
                                  MinWidth="200px" />

            <RadzenDataGridColumn TItem="ItemKategori" Title="Resim"
                                  Width="90px" TextAlign="TextAlign.Center"
                                  Sortable="false" Filterable="false">
                <Template Context="row">
                    @if (!string.IsNullOrWhiteSpace(row.ResimYolu))
                    {
                        <img src="@row.ResimYolu" alt="@row.Ad"
                             title="@row.Ad"
                             style="width:52px;height:52px;object-fit:cover;border-radius:8px;border:1px solid #e2e8f0;display:block;margin:0 auto;" />
                    }
                    else
                    {
                        <span style="color:#94a3b8;font-size:0.85rem;">—</span>
                    }
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="ItemKategori" Property="Aktif" Title="Aktif"
                                  Width="90px" TextAlign="TextAlign.Center">
                <Template Context="row">
                    <RadzenIcon Icon="@(row.Aktif ? "check_circle" : "cancel")"
                                Style="@(row.Aktif ? "color:#2e7d32" : "color:#c62828")" />
                </Template>
            </RadzenDataGridColumn>

            <RadzenDataGridColumn TItem="ItemKategori" Title="İşlemler"
                                  Width="120px" TextAlign="TextAlign.Center"
                                  Sortable="false" Filterable="false">
                <Template Context="row">
                    <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Info" Size="ButtonSize.Small"
                                  Variant="Variant.Flat"
                                  Click="@(() => OnDuzenleClick(row))"
                                  Disabled="@sadecOkuma"
                                  Style="@("margin-right:4px;" + (sadecOkuma ? "opacity:0.35;pointer-events:none;" : ""))"
                                  title="Düzenle" />
                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                  Variant="Variant.Flat"
                                  Click="@(() => OnSilClick(row))"
                                  Disabled="@sadecOkuma"
                                  Style="@(sadecOkuma ? "opacity:0.35;pointer-events:none;" : "")"
                                  title="Sil" />
                </Template>
            </RadzenDataGridColumn>

        </Columns>
    </RadzenDataGrid>
}

@code {
    private ItemKategori[] kategoriler = [];
    private bool isLoading = true;
    private bool sadecOkuma = false;

    private IList<ExportColumn<ItemKategori>> CiktiKolonlari() => new List<ExportColumn<ItemKategori>>
    {
        new() { Header = "ID",          Value = k => k.ID,        Align = ExportAlign.Right, Width = 0.6f },
        new() { Header = "Kategori Adı", Value = k => k.Ad,        Width = 1.6f },
        new() { Header = "Açıklama",    Value = k => k.Aciklama,  Width = 2.4f },
        new() { Header = "Resim Yolu",  Value = k => k.ResimYolu, Width = 1.6f },
        new() { Header = "Aktif",       Value = k => k.Aktif,     Align = ExportAlign.Center, Width = 0.7f },
    };

    protected override async Task OnInitializedAsync()
    {
        await AuthState.InitializeAsync();
        await YetkiSvc.EnsureReadyAsync();
        if (!YetkiSvc.ErişimVar("/kategoriler"))
        {
            Nav.NavigateTo("/erisim-engeli", true);
            return;
        }
        sadecOkuma = YetkiSvc.SadecOkuma("/kategoriler");
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        try { kategoriler = await DataSvc.GetKategori(); }
        finally { isLoading = false; }
    }

    private async Task OnYeniClick()
    {
        if (sadecOkuma) return;
        var result = await DialogSvc.OpenAsync<KategoriTnm>("Yeni Kategori",
            new Dictionary<string, object?> { { "Item", new ItemKategori { Aktif = true } } },
            new DialogOptions { Width = "500px", Resizable = false, Draggable = true, CloseDialogOnOverlayClick = false });
        if (result is true) await LoadAsync();
    }

    private async Task OnDuzenleClick(ItemKategori item)
    {
        if (sadecOkuma) return;
        var result = await DialogSvc.OpenAsync<KategoriTnm>("Kategori Düzenle",
            new Dictionary<string, object?> { { "Item", item } },
            new DialogOptions { Width = "500px", Resizable = false, Draggable = true, CloseDialogOnOverlayClick = false });
        if (result is true) await LoadAsync();
    }

    private async Task OnSilClick(ItemKategori item)
    {
        if (sadecOkuma) return;
        var onay = await DialogSvc.Confirm(
            DialogFragments.Html($"{DialogFragments.B(item.Ad)} kategorisini silmek istediğinizden emin misiniz?"), "Kategori Sil",
            new ConfirmOptions { OkButtonText = "Evet, Sil", CancelButtonText = "İptal" });
        if (onay != true) return;

        int userId = AuthState.CurrentUser?.ID ?? 0;
        var silItem = new ItemKategori { ID = item.ID, Ad = item.Ad, Aktif = item.Aktif, CreUser = item.CreUser, DelUser = userId };
        var result = await DataSvc.SetKategori(silItem);

        if (result.SonucKodu < 0)
            NotificationSvc.Notify(NotificationSeverity.Error, "Hata", result.SonucAciklama ?? "Silme işlemi başarısız.", 4000);
        else
        {
            NotificationSvc.Notify(NotificationSeverity.Success, "Başarılı", $"{item.Ad} silindi.", 3000);
            await LoadAsync();
        }
    }
}