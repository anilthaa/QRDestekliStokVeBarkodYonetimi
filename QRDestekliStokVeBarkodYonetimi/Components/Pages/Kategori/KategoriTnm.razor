@inject DataService DataSvc
@inject AuthStateService AuthState
@inject DialogService DialogSvc
@inject NotificationService NotificationSvc
@inject IWebHostEnvironment Env

<RadzenTemplateForm TItem="ItemKategori" Data="@model" Submit="@OnSubmitAsync" InvalidSubmit="@OnInvalidSubmit">

    <div class="form-shell rz-p-4">

        <div class="form-field">
            <RadzenLabel Text="Kategori Adı *" Component="Ad" />
            <RadzenTextBox @bind-Value="model.Ad" Name="Ad" Placeholder="Kategori adı giriniz"
                           Style="width:100%" Disabled="@AlanDevreDisi" />
            @if (!SadeceIncele)
            {
                <RadzenRequiredValidator Component="Ad" Text="Kategori adı zorunludur." Style="display:block" />
            }
        </div>

        <div class="form-field">
            <RadzenLabel Text="Açıklama" Component="Aciklama" />
            <RadzenTextArea @bind-Value="model.Aciklama" Name="Aciklama" Placeholder="Açıklama (opsiyonel)"
                            Style="width:100%" Rows="3" Disabled="@AlanDevreDisi" />
        </div>

        @if (!string.IsNullOrWhiteSpace(onizlemeResim))
        {
            <div @onclick="@(() => onizlemeResim = null)"
                 style="position:fixed; inset:0; background:rgba(0,0,0,0.82); z-index:9999;
                        display:flex; align-items:center; justify-content:center; cursor:zoom-out;">
                <img src="@onizlemeResim" alt="Tam görünüm"
                     style="max-width:90vw; max-height:90vh; border-radius:10px; box-shadow:0 4px 32px #000;" />
            </div>
        }

        <div class="form-field">
            <RadzenLabel Text="Kategori Resmi" />
            @if (!string.IsNullOrWhiteSpace(model.ResimYolu))
            {
                <div style="margin-bottom:0.5rem; position:relative; display:inline-block;">
                    <img src="@model.ResimYolu" alt="Kategori resmi"
                         style="max-height:120px; max-width:100%; border-radius:8px; border:1px solid #ddd; object-fit:cover; cursor:zoom-in;"
                         @onclick="@(() => onizlemeResim = model.ResimYolu)" />
                    @if (!SadeceIncele)
                    {
                        <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small"
                                      Variant="Variant.Flat"
                                      Style="position:absolute; top:4px; right:4px; padding:2px 6px;"
                                      Click="@ResimSil" title="Resmi kaldır" />
                    }
                </div>
            }
            @if (!SadeceIncele)
            {
                <InputFile OnChange="@OnResimSecildi" accept="image/*"
                           style="display:block; margin-top:4px;" disabled="@AlanDevreDisi" />
                @if (resimYukleniyor)
                {
                    <div style="font-size:0.8rem; color:#555; margin-top:4px;">
                        <RadzenProgressBar Value="100" Mode="ProgressBarMode.Indeterminate" Style="height:6px;" />
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(resimHata))
                {
                    <div style="font-size:0.8rem; color:#c62828; margin-top:4px;">@resimHata</div>
                }
            }
        </div>

        <div class="form-check-row">
            <RadzenCheckBox @bind-Value="model.Aktif" Name="Aktif" Disabled="@AlanDevreDisi" />
            <RadzenLabel Text="Aktif" Component="Aktif" />
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat"
                         AllowClose="false">@errorMessage</RadzenAlert>
        }

        <div class="form-actions">
            <RadzenButton ButtonStyle="ButtonStyle.Light" Text="@(SadeceIncele ? "Kapat" : "İptal")" Icon="cancel"
                          Click="@OnCancel" Disabled="@isBusy" />
            @if (!SadeceIncele)
            {
                <RadzenButton ButtonType="ButtonType.Submit" Text="Kaydet" Icon="save"
                              IsBusy="@isBusy" BusyText="Kaydediliyor..." />
            }
        </div>

    </div>

</RadzenTemplateForm>

@code {
    [Parameter] public ItemKategori? Item { get; set; }
    [Parameter] public bool SadeceIncele { get; set; }

    private ItemKategori model = new() { Aktif = true };
    private bool isBusy;
    private bool hatalariGoster;
    private string? errorMessage;

    private bool AlanDevreDisi => isBusy || SadeceIncele;

    private void OnInvalidSubmit() => hatalariGoster = true;
    private bool resimYukleniyor;
    private string? resimHata;
    private string? onizlemeResim;

    private static readonly string[] IzinliUzantilar = [".jpg", ".jpeg", ".png", ".gif", ".webp"];
    private const long MaxResimBoyutu = 5 * 1024 * 1024; // 5 MB

    protected override void OnParametersSet()
    {
        if (Item is not null)
        {
            model = new ItemKategori
            {
                ID        = Item.ID,
                Ad        = Item.Ad,
                Aciklama  = Item.Aciklama,
                ResimYolu = Item.ResimYolu,
                Aktif     = Item.Aktif,
                CreUser   = Item.CreUser,
                CreDate   = Item.CreDate,
                UpdUser   = Item.UpdUser,
                UpdDate   = Item.UpdDate,
                DelUser   = Item.DelUser,
                DelDate   = Item.DelDate
            };
        }
    }

    private async Task OnResimSecildi(InputFileChangeEventArgs e)
    {
        resimHata = null;
        var dosya = e.File;

        var uzanti = Path.GetExtension(dosya.Name).ToLowerInvariant();
        if (!IzinliUzantilar.Contains(uzanti))
        {
            resimHata = "Sadece .jpg, .jpeg, .png, .gif veya .webp dosyaları yüklenebilir.";
            return;
        }
        if (dosya.Size > MaxResimBoyutu)
        {
            resimHata = "Dosya boyutu 5 MB'ı geçemez.";
            return;
        }

        resimYukleniyor = true;
        try
        {
            var klasor = Path.Combine(Env.WebRootPath, "uploads", "kategoriler");
            Directory.CreateDirectory(klasor);

            if (!string.IsNullOrWhiteSpace(model.ResimYolu))
            {
                var eskiDosya = Path.Combine(Env.WebRootPath, model.ResimYolu.TrimStart('/').Replace('/', Path.DirectorySeparatorChar));
                if (File.Exists(eskiDosya)) File.Delete(eskiDosya);
            }

            var dosyaAdi = $"{Guid.NewGuid()}{uzanti}";
            var hedef = Path.Combine(klasor, dosyaAdi);

            await using var stream = dosya.OpenReadStream(MaxResimBoyutu);
            await using var fs = File.Create(hedef);
            await stream.CopyToAsync(fs);

            model.ResimYolu = $"/uploads/kategoriler/{dosyaAdi}";
        }
        catch (Exception ex)
        {
            resimHata = "Yükleme hatası: " + ex.Message;
        }
        finally
        {
            resimYukleniyor = false;
        }
    }

    private void ResimSil()
    {
        if (!string.IsNullOrWhiteSpace(model.ResimYolu))
        {
            var eskiDosya = Path.Combine(Env.WebRootPath, model.ResimYolu.TrimStart('/').Replace('/', Path.DirectorySeparatorChar));
            if (File.Exists(eskiDosya)) File.Delete(eskiDosya);
        }
        model.ResimYolu = null;
    }

    private async Task OnSubmitAsync()
    {
        errorMessage = null;
        hatalariGoster = true;
        isBusy = true;
        try
        {
            int userId = AuthState.CurrentUser?.ID ?? 0;

            if (model.ID == 0)
                model.CreUser = userId;
            else
                model.UpdUser = userId;

            model.DelUser = 0;

            var yeniKayit = model.ID == 0;
            var result = await DataSvc.SetKategori(model);

            if (result.SonucKodu < 0)
            {
                errorMessage = result.SonucAciklama ?? "Bir hata oluştu.";
                return;
            }

            NotificationSvc.Notify(NotificationSeverity.Success, "Başarılı",
                yeniKayit ? "Kategori eklendi." : "Kategori güncellendi.", 3000);

            DialogSvc.Close(true);
        }
        catch (Exception ex)
        {
            errorMessage = $"Beklenmeyen hata: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private void OnCancel() => DialogSvc.Close(false);
}
