@page "/kullanici-tipler"
@layout QRDestekliStokVeBarkodYonetimi.Components.Layout.MainLayout
@rendermode InteractiveServer

@implements IDisposable

@inject NavigationManager Nav
@inject YetkiService YetkiSvc

<PageTitle>Kullanıcı Tipleri</PageTitle>

<div class="page-header">
    <h3 class="page-header-title">Kullanıcı Tipi Listesi</h3>
    <div class="page-header-actions">
        <ExportButton TItem="ItemKullaniciTip"
                      Items="@tipler"
                      Title="Kullanıcı Tipi Listesi"
                      FileName="kullanici-tipi-listesi"
                      Columns="@CiktiKolonlari()" />
        <RadzenButton Text="Yeni Kullanıcı Tipi" Icon="add" ButtonStyle="ButtonStyle.Primary"
                      Click="@OnYeniClick"
                      Disabled="@sadecOkuma"
                      Style="@(sadecOkuma ? "opacity:0.35;pointer-events:none;" : "")" />
    </div>
</div>

@if (isLoading)
{
    <div style="display:flex; justify-content:center; padding:2rem;">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate"
                                   Size="ProgressBarCircularSize.Large" />
    </div>
}
else
{
    <RadzenDataGrid @ref="gridRef" Data="@filtreliTipler" TItem="ItemKullaniciTip" AllowSorting="true"
                    AllowFiltering="true" FilterMode="FilterMode.Simple"
                    FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                    AllowPaging="false" AllowVirtualization="true" PageSize="25"
                    VirtualizationOverscanCount="3"
                    class="liste-grid-virtual"
                    EmptyText="Kayıt bulunamadı."
                    ColumnWidth="200px">
        <Columns>
            <RadzenDataGridColumn TItem="ItemKullaniciTip" Property="ID" Title="Sıra" Width="@GridSiraYardimci.KolonGenisligi" MinWidth="@GridSiraYardimci.KolonGenisligi"
                                  Frozen="true" Filterable="false"
                                  SortComparer="@GridSiraYardimci.SiralamaIndeksiComparer(filtreliTipler)"
                                  TextAlign="TextAlign.Center" CssClass="grid-sira-kolon">
                <Template Context="row">
                    @GridSiraYardimci.ListeSirasi(filtreliTipler, row)
                </Template>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ItemKullaniciTip" Property="Ad" Title="Kullanıcı Tipi Adı" MinWidth="200px" />
            <RadzenDataGridColumn TItem="ItemKullaniciTip" Property="Aktif" Title="Aktif" Width="90px" TextAlign="TextAlign.Center">
                <Template Context="row">
                    <RadzenIcon Icon="@(row.Aktif == true ? "check_circle" : "cancel")"
                                Style="@(row.Aktif == true ? "color:#2e7d32" : "color:#c62828")" />
                </Template>
                <FilterTemplate>
                    <GridBoolFilter @bind-Value="@aktifFiltre" />
                </FilterTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ItemKullaniciTip" Property="Varsayilan" Title="Varsayılan" Width="110px" TextAlign="TextAlign.Center">
                <Template Context="row">
                    @if (row.Varsayilan)
                    {
                        <RadzenBadge Text="Varsayılan" BadgeStyle="BadgeStyle.Info" />
                    }
                    else
                    {
                        <span style="color:var(--rz-text-secondary-color); font-size:0.85rem;">—</span>
                    }
                </Template>
                <FilterTemplate>
                    <GridBoolFilter @bind-Value="@varsayilanFiltre" />
                </FilterTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="ItemKullaniciTip" Title="" Width="48px" TextAlign="TextAlign.Center"
                                  Sortable="false" Filterable="false">
                <Template Context="row">
                    <GridIslemMenuButonu Click="@(e => IslemlerMenuAc(e, row))" />
                </Template>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
}

@code {
    private RadzenDataGrid<ItemKullaniciTip>? gridRef;
    private ItemKullaniciTip[] tipler = [];
    private bool isLoading = true;
    private bool sadecOkuma = false;
    private bool yetkiSayfasiErisim = false;
    private bool? aktifFiltre;
    private bool? varsayilanFiltre;
    private ItemKullaniciTip? menuSatir;

    private ItemKullaniciTip[] filtreliTipler => tipler.Where(t =>
        GridFilterHelper.BoolEslesir(t.Aktif, aktifFiltre) &&
        GridFilterHelper.BoolEslesir(t.Varsayilan, varsayilanFiltre)).ToArray();

    private IList<ExportColumn<ItemKullaniciTip>> CiktiKolonlari()
    {
        var liste = tipler.ToList();
        return new List<ExportColumn<ItemKullaniciTip>>
    {
        new() { Header = "Sıra",              Value = t => GridSiraYardimci.ExportSirasi(liste, t), Align = ExportAlign.Right, Width = 0.6f },
        new() { Header = "Kullanıcı Tipi Adı", Value = t => t.Ad,    Width = 2.2f },
        new() { Header = "Aktif",             Value = t => t.Aktif, Align = ExportAlign.Center, Width = 0.7f },
        new() { Header = "Varsayılan",        Value = t => t.Varsayilan, Align = ExportAlign.Center, Width = 0.8f },
    };
    }

    protected override async Task OnInitializedAsync()
    {
        await AuthState.InitializeAsync();
        await YetkiSvc.EnsureReadyAsync();
        if (!YetkiSvc.ErişimVar("/kullanici-tipler"))
        {
            Nav.NavigateTo("/erisim-engeli", true);
            return;
        }
        sadecOkuma = YetkiSvc.SadecOkuma("/kullanici-tipler");
        yetkiSayfasiErisim = YetkiSvc.ErişimVar("/kullanici-tip-yetki");
        Nav.LocationChanged += OnLocationChanged;
        await LoadAsync();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var path = new Uri(e.Location).AbsolutePath.TrimEnd('/');
        if (string.Equals(path, "/kullanici-tipler", StringComparison.OrdinalIgnoreCase))
            _ = InvokeAsync(() => LoadAsync(tamSpinner: false));
    }

    public void Dispose()
        => Nav.LocationChanged -= OnLocationChanged;

    private async Task LoadAsync(bool tamSpinner = true)
    {
        if (tamSpinner) isLoading = true;
        try { tipler = await DataSvc.GetKullaniciTip(); }
        finally { if (tamSpinner) isLoading = false; }

        await InvokeAsync(StateHasChanged);
        if (gridRef is not null)
            await gridRef.Reload();
    }

    private async Task OnYeniClick()
    {
        if (sadecOkuma) return;
        var result = await DialogSvc.OpenAsync<KullaniciTipTnm>("Yeni Kullanıcı Tipi",
            new Dictionary<string, object?> { { "Item", new ItemKullaniciTip { Aktif = true } } },
            new DialogOptions { Width = "480px", Resizable = false, Draggable = true, CloseDialogOnOverlayClick = false });
        if (result is bool kaydedildi && kaydedildi)
            await LoadAsync(tamSpinner: false);
    }

    private void IslemlerMenuAc(MouseEventArgs args, ItemKullaniciTip row)
    {
        menuSatir = row;
        ContextMenuSvc.Open(args,
            new List<ContextMenuItem>
            {
                new() { Text = "İncele", Icon = "visibility", Value = "incele" },
                new() { Text = "Düzenle", Icon = "edit", Value = "duzenle", Disabled = sadecOkuma },
                new() { Text = "Yetki Yönetimi", Icon = "shield", Value = "yetki", Disabled = !yetkiSayfasiErisim },
                new() { Text = "Sil", Icon = "delete", Value = "sil", Disabled = sadecOkuma }
            },
            OnIslemMenuSecildi);
    }

    private void OnIslemMenuSecildi(MenuItemEventArgs args)
    {
        _ = InvokeAsync(async () =>
        {
            if (menuSatir is null)
                return;

            var row = menuSatir;
            menuSatir = null;

            switch (args.Value?.ToString())
            {
                case "incele":
                    await OnInceleClick(row);
                    break;
                case "duzenle":
                    await OnDuzenleClick(row);
                    break;
                case "yetki":
                    ContextMenuSvc.Close();
                    Nav.NavigateTo($"/kullanici-tip-yetki/{row.ID}");
                    break;
                case "sil":
                    await OnSilClick(row);
                    break;
            }
        });
    }

    private async Task OnInceleClick(ItemKullaniciTip item)
    {
        await DialogSvc.OpenAsync<KullaniciTipTnm>("Kullanıcı Tipi İncele",
            new Dictionary<string, object?> { { "Item", item }, { "SadeceIncele", true } },
            new DialogOptions { Width = "480px", Resizable = false, Draggable = true, CloseDialogOnOverlayClick = false });
    }

    private async Task OnDuzenleClick(ItemKullaniciTip item)
    {
        if (sadecOkuma) return;
        var result = await DialogSvc.OpenAsync<KullaniciTipTnm>("Kullanıcı Tipi Düzenle",
            new Dictionary<string, object?> { { "Item", item } },
            new DialogOptions { Width = "480px", Resizable = false, Draggable = true, CloseDialogOnOverlayClick = false });
        if (result is bool kaydedildi && kaydedildi)
            await LoadAsync(tamSpinner: false);
    }

    private async Task OnSilClick(ItemKullaniciTip item)
    {
        if (sadecOkuma) return;
        var onay = await DialogSvc.Confirm(
            DialogFragments.Html($"{DialogFragments.B(item.Ad)} kullanıcı tipini silmek istediğinizden emin misiniz?"), "Kullanıcı Tipi Sil",
            new ConfirmOptions { OkButtonText = "Evet, Sil", CancelButtonText = "İptal" });
        if (onay != true) return;

        int userId = AuthState.CurrentUser?.ID ?? 0;
        var silItem = new ItemKullaniciTip
        {
            ID = item.ID, Ad = item.Ad, Aktif = item.Aktif, Varsayilan = item.Varsayilan,
            CreUser = item.CreUser, DelUser = userId
        };
        var result = await DataSvc.SetKullaniciTip(silItem);
        if (result.SonucKodu < 0)
        {
            await DialogSvc.Alert(
                DialogFragments.Html(result.SonucAciklama ?? "Silme işlemi başarısız."),
                "Kullanıcı Tipi Silinemez",
                new AlertOptions { OkButtonText = "Tamam" });
        }
        else
        {
            NotificationSvc.Notify(NotificationSeverity.Success, "Başarılı", $"{item.Ad} silindi.", 3000);
            await LoadAsync(tamSpinner: false);
        }
    }
}