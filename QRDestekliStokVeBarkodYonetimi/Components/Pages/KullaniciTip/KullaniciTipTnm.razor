<RadzenTemplateForm TItem="ItemKullaniciTip" Data="@model" Submit="@OnSubmitAsync" InvalidSubmit="@OnInvalidSubmit">

    <div class="form-shell rz-p-4">

        <div class="form-field">
            <RadzenLabel Text="Kullanıcı Tipi Adı *" Component="Ad" />
            <RadzenTextBox @bind-Value="model.Ad" Name="Ad" Placeholder="Tip adı giriniz"
                           Style="width:100%" Disabled="@AlanDevreDisi" />
            @if (!SadeceIncele)
            {
                <RadzenRequiredValidator Component="Ad" Text="Kullanıcı tipi adı zorunludur." Style="display:block" />
            }
        </div>

        <div class="form-check-row">
            <RadzenCheckBox @bind-Value="model.Aktif" Name="Aktif" Disabled="@AlanDevreDisi" />
            <RadzenLabel Text="Aktif" Component="Aktif" />
        </div>

        <div class="form-check-row" style="align-items:flex-start;">
            <RadzenCheckBox @bind-Value="model.Varsayilan" Name="Varsayilan" Disabled="@AlanDevreDisi" />
            <RadzenLabel Text="Yeni kayıt olan kullanıcılar için varsayılan tip"
                         Component="Varsayilan"
                         Style="line-height:1.35;" />
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" Variant="Variant.Flat"
                         AllowClose="false">@errorMessage</RadzenAlert>
        }

        <div class="form-actions">
            <RadzenButton ButtonStyle="ButtonStyle.Light" Text="@(SadeceIncele ? "Kapat" : "İptal")" Icon="cancel"
                          Click="@OnCancel" Disabled="@isBusy" />
            @if (!SadeceIncele)
            {
                <RadzenButton ButtonType="ButtonType.Submit" Text="Kaydet" Icon="save"
                              IsBusy="@isBusy" BusyText="Kaydediliyor..." />
            }
        </div>

    </div>

</RadzenTemplateForm>

@code {
    [Parameter] public ItemKullaniciTip? Item { get; set; }
    [Parameter] public bool SadeceIncele { get; set; }

    private ItemKullaniciTip model = new() { Aktif = true };
    private bool isBusy;
    private bool hatalariGoster;
    private string? errorMessage;

    private bool AlanDevreDisi => isBusy || SadeceIncele;

    private void OnInvalidSubmit() => hatalariGoster = true;

    protected override void OnParametersSet()
    {
        if (Item is not null)
        {
            model = new ItemKullaniciTip
            {
                ID      = Item.ID,
                Ad      = Item.Ad,
                Aktif   = Item.Aktif,
                Varsayilan = Item.Varsayilan,
                CreUser = Item.CreUser,
                CreDate = Item.CreDate,
                UpdUser = Item.UpdUser,
                UpdDate = Item.UpdDate,
                DelUser = Item.DelUser,
                DelDate = Item.DelDate
            };
        }
    }

    private async Task OnSubmitAsync()
    {
        errorMessage = null;
        hatalariGoster = true;
        isBusy = true;
        try
        {
            int userId = AuthState.CurrentUser?.ID ?? 0;

            if (model.ID == 0)
                model.CreUser = userId;
            else
                model.UpdUser = userId;

            model.DelUser = 0;

            var yeniKayit = model.ID == 0;
            var result = await DataSvc.SetKullaniciTip(model);

            if (result.SonucKodu < 0)
            {
                errorMessage = result.SonucAciklama ?? "Bir hata oluştu.";
                return;
            }

            NotificationSvc.Notify(NotificationSeverity.Success, "Başarılı",
                yeniKayit ? "Kullanıcı tipi eklendi." : "Kullanıcı tipi güncellendi.", 3000);

            DialogSvc.Close(true);
        }
        catch (Exception ex)
        {
            errorMessage = $"Beklenmeyen hata: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private void OnCancel() => DialogSvc.Close(false);
}
